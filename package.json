{
  "name": "directory-template",
  "version": "2.0.0",
  "description": "Directory site template built on AstroWind + Tailwind CSS",
  "type": "module",
  "private": true,
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >= 21.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build:contacts": "npx tsx src/scripts/build-listing-contacts.ts",
    "build": "astro build && npx pagefind --site dist && npx wrangler pages functions build _functions --outdir dist/worker-build && cp dist/worker-build/index.js dist/_worker.js && rm -rf dist/worker-build",
    "preview": "astro preview",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name surveyslate --branch main"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.4.2",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/inter": "^5.2.6",
    "astro": "^5.12.9",
    "astro-icon": "^1.1.5",
    "leaflet": "^1.9.4",
    "limax": "4.1.0",
    "lodash.merge": "^4.6.2",
    "satori": "^0.25.0",
    "unpic": "^4.1.3"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.3.3",
    "@astrojs/tailwind": "^5.1.5",
    "@iconify-json/tabler": "^1.2.20",
    "@tailwindcss/typography": "^0.5.16",
    "@types/leaflet": "^1.9.8",
    "@types/lodash.merge": "^4.6.9",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.3.0",
    "reading-time": "^1.5.0",
    "sharp": "0.34.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "unist-util-visit": "^5.0.0",
    "wrangler": "^4.74.0"
  }
}
