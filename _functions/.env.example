# ============================================================
# Directory Factory — Cloudflare Pages Environment Variables
# Copy to your CF Pages project settings or wrangler.toml [vars]
# ============================================================

# D1 database binding (configured in wrangler.toml, not here)
# LEADS_DB = bound via wrangler.toml

# R2 bucket for photo uploads (configured in wrangler.toml)
# PHOTOS = bound via wrangler.toml

# --- Site Identity (REQUIRED — change for each vertical) ---
SITE_DOMAIN=yourdomain.com
SITE_NAME=YourDirectory
SITE_TAGLINE=Find professionals near you
SITE_FROM_EMAIL=YourDirectory <noreply@yourdomain.com>
COMPANY_ADDRESS=

# --- Listmonk Email (REQUIRED for email features) ---
LISTMONK_URL=https://mail.firestick.io
LISTMONK_USER=admin
LISTMONK_PASS=
LISTMONK_LIST_ID=
LISTMONK_MAGICLINK_TEMPLATE_ID=
LISTMONK_GUIDE_TEMPLATE_ID=
LISTMONK_PASSTHROUGH_TEMPLATE_ID=

# --- Security ---
TURNSTILE_SECRET_KEY=
HASH_SALT=

# --- Stripe Payments (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Twilio Phone Verification (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Admin ---
ADMIN_EMAIL=
