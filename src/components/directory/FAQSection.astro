---
// Per-vertical FAQ section. Reads from src/data/faqs.json (generated by
// scripts/generate_faqs.py). Renders accordion + emits FAQPage JSON-LD
// for SEO.
import FAQAccordion from './FAQAccordion.astro';

interface Props {
  title?: string;
  subtitle?: string;
  limit?: number;          // optional cap, e.g. show 6 on home, all on /faq/
}

const { title = 'Frequently Asked Questions', subtitle, limit } = Astro.props;

let faqs: Array<{ question: string; answer: string }> = [];
try {
  const mod = await import('~/data/faqs.json');
  faqs = (mod.default ?? mod) as typeof faqs;
} catch {
  faqs = [];
}

const shown = limit && limit > 0 ? faqs.slice(0, limit) : faqs;

const jsonLd = shown.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: shown.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;
---

{shown.length > 0 && (
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{title}</h2>
        {subtitle && <p class="text-slate-500 mt-3 max-w-xl mx-auto">{subtitle}</p>}
      </div>
      <FAQAccordion faqs={shown} />
    </div>
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </section>
)}
