---
interface StateEntry {
  stateSlug: string;
  stateName: string;
  state: string;
  cityCount: number;
  listingCount: number;
}

interface Props {
  states: StateEntry[];
}

const { states } = Astro.props;
---
<div>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
    {states.map((s) => (
      <a href={`/states/${s.stateSlug}/`} class="bg-white rounded-xl border border-gray-200 p-4 no-underline hover:border-primary-300 hover:shadow-sm transition-all group">
        <span class="block font-semibold text-gray-900 group-hover:text-primary-600">{s.stateName}</span>
        <span class="text-sm text-gray-500">{s.cityCount} {s.cityCount === 1 ? 'city' : 'cities'}</span>
        {s.listingCount > 0 && (
          <span class="text-xs text-primary-600 ml-2">{s.listingCount} listings</span>
        )}
      </a>
    ))}
  </div>
</div>
