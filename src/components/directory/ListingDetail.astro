---
import ReviewStars from './ReviewStars.astro';
import ReviewHighlights from './ReviewHighlights.astro';
import SentimentBadge from './SentimentBadge.astro';
import SchemaDetailSection from './SchemaDetailSection.astro';
import config from '~/config';
import citiesJson from '~/data/cities.json';
import { getListingsForCity } from '~/lib/listings';
import type { Sentiment } from '~/lib/listings';
import { titleCase, smartLower } from '~/utils/utils';

interface Props {
  listing: {
    slug: string;
    name: string;
    city: string;
    state: string;
    address: string;
    lat: number;
    lng: number;
    phone?: string;
    website?: string;
    email?: string;
    rating: number;
    review_count: number;
    description?: string;
    certifications?: string[];
    services?: string[];
    years_experience?: number;
    coverage_area?: string;
    equipment?: string[];
    photos?: { url: string; alt?: string }[];
    claimed: boolean;
    featured: boolean;
    sentiment?: Sentiment | null;
    demo_reel_url?: string;
    scraped_at?: string;
  };
}

const { listing } = Astro.props;
const cityData = citiesJson.find((c: any) => c.slug === listing.city || c.city === listing.city);
const citySlug = cityData?.slug || listing.city;
const cityDisplay = cityData?.city || listing.city;
const stateDisplay = listing.state;

// Initials
const words = listing.name.trim().split(/\s+/).filter((w: string) => w.length > 0);
const initials = words.length >= 2
  ? (words[0][0] + words[1][0]).toUpperCase()
  : listing.name.slice(0, 2).toUpperCase();

// Competitors in same city
const cityListings = getListingsForCity(citySlug);
const competitors = cityListings
  .filter(l => l.slug !== listing.slug && (l.claimed || l.featured || l.review_count > 0))
  .slice(0, 3);

// Completeness score
const completenessItems = [
  { label: 'Business name & location', done: true },
  { label: 'Business description', done: !!listing.description },
  { label: 'Photos & portfolio', done: false },
  { label: config.primaryCredential ? `Certifications (${config.primaryCredential})` : 'Certifications', done: !!(listing.certifications && listing.certifications.length > 0) },
  { label: 'Service area & availability', done: !!(listing.services && listing.services.length > 0) },
  { label: 'Client reviews', done: listing.review_count > 0 },
];
const completedCount = completenessItems.filter(i => i.done).length;
const completenessPercent = Math.round((completedCount / completenessItems.length) * 100);
---

<div class="listing-detail" data-listing-slug={listing.slug}>

  <!-- ===== PROVIDER VIEW: Claim Banner + Completeness + FOMO (hidden by default) ===== -->
  <div id="provider-view" class="hidden">

    <!-- Claim Banner -->
    <div class="claim-banner">
      <div class="claim-banner-icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg></div>
      <div class="claim-banner-text">
        <h3>Is this your business?</h3>
        <p>Claim your free listing to update info, respond to quote requests, and appear higher in results.</p>
      </div>
      <a href={`/provider/login?listing=${listing.slug}`} class="btn-action-dark ml-auto whitespace-nowrap">
        Claim Listing — Free
      </a>
    </div>

    <!-- Profile Completeness -->
    <div class="card-section">
      <h3 class="text-sm font-bold mb-3">Profile Completeness — {completenessPercent}%</h3>
      <div class="completeness-bar">
        <div class={`completeness-fill ${completenessPercent <= 40 ? 'low' : completenessPercent <= 70 ? 'mid' : 'high'}`} style={`width: ${completenessPercent}%`}></div>
      </div>
      <div class="completeness-items">
        {completenessItems.map(item => (
          <div class={`completeness-item ${item.done ? 'done' : 'missing'}`}>
            <span class="icon">{item.done ? <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> : <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2"/></svg>}</span>
            {item.label}
          </div>
        ))}
      </div>
    </div>

    <!-- FOMO Banner -->
    <div class="fomo-banner">
      <div class="fomo-icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg></div>
      <div class="fomo-text">
        {titleCase(config.buyerPersona || 'Buyers')} are actively searching for {smartLower(config.primaryKeyword || config.name)} in <strong>{cityDisplay}</strong>.
        Quote requests are being sent to other providers in your area.
      </div>
    </div>
  </div>

  <!-- ===== LISTING STATUS BADGE (shown for organic attorney traffic) ===== -->
  <div id="verified-badge" class="verified-badge-bar">
    <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <span>{listing.scraped_at ? `Last updated: ` : 'Listed provider'}</span>
    {listing.scraped_at && <strong>{new Date(listing.scraped_at).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</strong>}
  </div>

  <!-- ===== HEADER CARD ===== -->
  <div class="listing-header">
    <!-- Cover -->
    {listing.claimed && listing.featured ? (
      <div class="header-cover claimed-cover"></div>
    ) : (
      <div class="header-cover" id="cover-area">
        <div class="cover-placeholder provider-only hidden">+ Add a cover photo</div>
      </div>
    )}

    <div class="header-content">
      <!-- Avatar -->
      <div class={`avatar ${listing.claimed ? 'claimed' : 'unclaimed'}`} id="listing-avatar">
        {initials}
      </div>

      <div class="header-top">
        <div class="header-info">
          <h1>
            {listing.name}
            {listing.claimed ? (
              <span class="verified-badge">✓ Verified</span>
            ) : (
              <span class="unverified-tag provider-only hidden">Unverified</span>
            )}
            {listing.featured && (
              <span class="sponsored-badge" title="This provider pays for premium placement"><svg class="w-4 h-4 inline" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg> Sponsored</span>
            )}
          </h1>
          <div class="location">{cityDisplay}, {stateDisplay}</div>
          <div class="rating-row">
            {listing.review_count > 0 ? (
              <ReviewStars rating={listing.rating} count={listing.review_count} />
            ) : (
              <span class="no-reviews">No reviews yet</span>
            )}
            {listing.sentiment && <SentimentBadge label={listing.sentiment.label} score={listing.sentiment.score} />}
          </div>
        </div>

        <div class="header-actions">
          <a href="#contact-form-card" class="btn-action-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            Request Quote
          </a>
          {listing.phone && listing.claimed && (
            <a href={`tel:${listing.phone}`} class="btn-action-secondary">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {listing.phone}
            </a>
          )}
          {listing.phone && !listing.claimed && (
            <button class="btn-action-secondary contact-gate-btn" data-gate-type="phone" data-gate-value={listing.phone}>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <span class="gated-label">Show Phone Number</span>
            </button>
          )}
          {listing.website && listing.claimed && (
            <a href={listing.website} target="_blank" rel="noopener noreferrer" class="btn-action-secondary">
              Visit Website
            </a>
          )}
          {listing.website && !listing.claimed && (
            <button class="btn-action-secondary contact-gate-btn" data-gate-type="website" data-gate-value={listing.website}>
              <span class="gated-label">Show Website</span>
            </button>
          )}
          {listing.demo_reel_url && (
            <a href={listing.demo_reel_url} target="_blank" rel="noopener noreferrer" class="btn-action-dark">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              Watch Demo Reel
            </a>
          )}
        </div>
      </div>

      <!-- Description -->
      {listing.description ? (
        <p class="description" id="listing-description" set:html={listing.description.replace(/\n/g, '<br />')} />
      ) : (
        <div class="description placeholder provider-only hidden">
          No description added yet. Attorneys see this when evaluating providers — tell them why you're the right choice.
        </div>
      )}

      <!-- Services -->
      {listing.services && listing.services.length > 0 && (
        <div class="services-tags" id="listing-services">
          {listing.services.map(svc => (
            <span class="tag active">{svc}</span>
          ))}
          <span class="tag ghost provider-only hidden">+ Add more</span>
        </div>
      )}

      <!-- Claim prompt (visible to all visitors for unclaimed listings) -->
      {!listing.claimed && (
        <div class="claim-prompt" id="claim-prompt">
          <span>Is this your business?</span>
          <a href={`/provider/login?listing=${listing.slug}`}>Claim this listing &mdash; free</a>
        </div>
      )}
    </div>
  </div>

  <!-- Blurred stats section removed — was hardcoded fake data -->

  <!-- ===== EMPTY SECTIONS (provider view — unclaimed only) ===== -->
  {!listing.claimed && (
    <>
      <!-- Empty Photo Gallery -->
      <div class="empty-section provider-only hidden">
        <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg> Photos & Portfolio</h2>
        <div class="gallery-placeholder">
          {[1,2,3,4].map(() => (
            <div class="gallery-slot">+</div>
          ))}
        </div>
        <a href={`/provider/login?listing=${listing.slug}`} class="empty-cta">Claim to Add Photos</a>
      </div>

      <!-- Empty About -->
      <div class="empty-section provider-only hidden">
        <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg> About {listing.name}</h2>
        <div class="placeholder-lines">
          <div class="placeholder-line" style="width:90%"></div>
          <div class="placeholder-line" style="width:80%"></div>
          <div class="placeholder-line" style="width:60%"></div>
          <div class="placeholder-line" style="width:90%"></div>
          <div class="placeholder-line" style="width:40%"></div>
        </div>
        <a href={`/provider/login?listing=${listing.slug}`} class="empty-cta">Claim to Add Details</a>
      </div>

      <!-- Empty Reviews -->
      <div class="empty-section provider-only hidden">
        <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg> Client Reviews</h2>
        <div class="placeholder-lines">
          <div class="placeholder-line" style="width:80%"></div>
          <div class="placeholder-line" style="width:60%"></div>
          <div style="height:16px;"></div>
          <div class="placeholder-line" style="width:90%"></div>
          <div class="placeholder-line" style="width:40%"></div>
        </div>
        <a href={`/provider/login?listing=${listing.slug}`} class="empty-cta">Claim to Collect Reviews</a>
      </div>
    </>
  )}

  <!-- ===== REAL CONTENT SECTIONS ===== -->

  <!-- Photo Gallery -->
  {listing.photos && listing.photos.length > 0 ? (
    <div class="card-section" id="photo-gallery-slot">
      <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg> Photos & Portfolio</h2>
      <div class={`gallery-grid ${listing.photos.length >= 5 ? 'has-hero' : ''}`}>
        {listing.photos.map((photo, i) => (
          <img
            src={photo.url}
            alt={photo.alt || `${listing.name} photo ${i + 1}`}
            loading="lazy"
            class={i === 0 && listing.photos!.length >= 5 ? 'hero' : ''}
          />
        ))}
      </div>
    </div>
  ) : (
    <div id="photo-gallery-slot"></div>
  )}

  <!-- About / Credentials Grid -->
  {(listing.certifications?.length || listing.years_experience) && (
    <div class="card-section">
      <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg> Credentials & Experience</h2>
      <div class="about-grid">
        {listing.years_experience && (
          <div class="about-card">
            <div class="about-card-label">Years in Business</div>
            <div class="about-card-value">{listing.years_experience}+</div>
          </div>
        )}
        {listing.certifications && listing.certifications.length > 0 && (
          <div class="about-card">
            <div class="about-card-label">Certifications</div>
            <div class="about-card-value" id="listing-certifications">
              {listing.certifications.join(', ')}
            </div>
          </div>
        )}
        {listing.review_count > 0 && (
          <div class="about-card">
            <div class="about-card-label">Client Rating</div>
            <div class="about-card-value">{listing.rating}/5 ({listing.review_count} reviews)</div>
          </div>
        )}
      </div>
    </div>
  )}

  <!-- Equipment -->
  {listing.equipment && listing.equipment.length > 0 && (
    <div class="card-section">
      <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9.75a2.25 2.25 0 002.25-2.25V7.5a2.25 2.25 0 00-2.25-2.25H4.5A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/></svg> Equipment</h2>
      <div class="equipment-grid">
        {listing.equipment.map(item => (
          <div class="equipment-card">
            <svg class="equipment-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Coverage Area -->
  {listing.coverage_area && (
    <div class="card-section">
      <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418"/></svg> Coverage Area</h2>
      <p class="coverage-text">{listing.coverage_area}</p>
    </div>
  )}

  <!-- Schema-driven additional details -->
  <SchemaDetailSection schema={config.listings.schema} values={listing as unknown as Record<string, unknown>} />

  <!-- Sentiment & Review Highlights -->
  {listing.sentiment && (
    <div class="card-section" id="reviews-section">
      <ReviewHighlights
        label={listing.sentiment.label}
        score={listing.sentiment.score}
        keywords={listing.sentiment.keywords}
        highlights={listing.sentiment.highlights}
        summary={listing.sentiment.summary}
      />
    </div>
  )}

  <!-- Map -->
  <div class="card-section map-section">
    <h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg> Location</h2>
    <p class="map-address">{listing.address || `${cityDisplay}, ${stateDisplay}`}</p>
    <div id="listing-map" class="listing-map" data-lat={listing.lat} data-lng={listing.lng} data-name={listing.name}></div>
  </div>

  <!-- Also in This City -->
  {competitors.length > 0 && (
    <div class="card-section" id="also-in-city">
      <h2>Also in {cityDisplay}</h2>
      <div class="competitor-list">
        {competitors.map(comp => {
          const compWords = comp.name.split(/\s+/);
          const compInitials = compWords.length >= 2 ? (compWords[0][0] + compWords[1][0]).toUpperCase() : comp.name.slice(0,2).toUpperCase();
          return (
            <a href={`/listing/${comp.slug}/`} class="competitor-row">
              <div class={`competitor-avatar ${comp.featured ? 'bg-blue-600' : comp.claimed ? 'bg-green-600' : 'bg-gray-400'}`}>
                {compInitials}
              </div>
              <div class="competitor-info">
                <div class="competitor-name">{comp.name}</div>
                <div class="competitor-meta">
                  {comp.review_count > 0 ? `★ ${comp.rating} · ${comp.review_count} reviews` : 'No reviews'}
                  {comp.claimed ? ' · Claimed' : ''}
                </div>
              </div>
              {comp.featured && (
                <span class="competitor-badge">Featured</span>
              )}
            </a>
          );
        })}
      </div>
    </div>
  )}

  <!-- Competitor Peek — provider view (amber border variant) -->
  {!listing.claimed && competitors.length > 0 && (
    <div class="card-section competitor-peek provider-only hidden">
      <h3 class="text-sm font-bold text-amber-900 mb-3"><svg class="w-4 h-4 inline-block align-text-bottom text-amber-500" fill="currentColor" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg> Other providers in {cityDisplay} attorneys are viewing</h3>
      <div class="competitor-list">
        {competitors.map(comp => {
          const compWords = comp.name.split(/\s+/);
          const compInitials = compWords.length >= 2 ? (compWords[0][0] + compWords[1][0]).toUpperCase() : comp.name.slice(0,2).toUpperCase();
          return (
            <div class="competitor-row">
              <div class={`competitor-avatar ${comp.featured ? 'bg-blue-600' : comp.claimed ? 'bg-green-600' : 'bg-gray-400'}`}>
                {compInitials}
              </div>
              <div class="competitor-info">
                <div class="competitor-name">{comp.name}</div>
                <div class="competitor-meta">
                  {comp.review_count > 0 ? `★ ${comp.rating} · ${comp.review_count} reviews` : 'No reviews'}
                  {comp.claimed ? ' · Claimed' : ''}
                </div>
              </div>
              {comp.featured && (
                <span class="competitor-badge">Featured</span>
              )}
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- Recent Activity section removed — was hardcoded fake data -->

  <!-- Upgrade CTA (provider view only) -->
  {!listing.claimed && (
    <div class="upgrade-section provider-only hidden">
      <h2><svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg> Get Sponsored in {cityDisplay}</h2>
      <p class="upgrade-subtitle">Appear above every other provider. Only 2 Sponsored spots available per city.</p>
      <div class="upgrade-features">
        <div class="upgrade-feature"><span class="check">✓</span> Pinned to #1 in {cityDisplay}</div>
        <div class="upgrade-feature"><span class="check">✓</span> "Sponsored" badge</div>
        <div class="upgrade-feature"><span class="check">✓</span> Quotes to your inbox</div>
        <div class="upgrade-feature"><span class="check">✓</span> Monthly impressions report</div>
        <div class="upgrade-feature"><span class="check">✓</span> Priority in searches</div>
        <div class="upgrade-feature"><span class="check">✓</span> Verified badge</div>
      </div>
      <a href={config.stripeSponsoredLink || '/advertise/'} target="_blank" rel="noopener"
        class="btn-action-amber">
        Get Sponsored — $79/mo
      </a>
      <p class="upgrade-note">No contracts · No setup fees · Cancel anytime</p>
    </div>
  )}

  <!-- Mobile sticky CTA -->
  <div class="mobile-cta">
    <a href="#contact-form-card" class="btn-action-primary flex-1">Request a Free Quote</a>
    {listing.phone && (
      <a href={`tel:${listing.phone}`} class="mobile-cta-phone" aria-label="Call">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      </a>
    )}
  </div>

  <!-- Footer links -->
  <div class="listing-footer">
    <p>
      <span>Is this your business? </span>
      <a href={`/removal-request/?listing=${listing.slug}&name=${encodeURIComponent(listing.name)}`}>Request removal</a>
      <span> · </span>
      <a href={`mailto:${config.contactEmail}?subject=Correction Request: ${listing.name}&body=I would like to correct information on the listing for ${listing.name}. The corrections needed are: `}>Request correction</a>
    </p>
    <p class="disclaimer">Listing does not constitute verification of licensing or credentials. <a href="/editorial-guidelines/">Learn more</a></p>
  </div>
</div>

