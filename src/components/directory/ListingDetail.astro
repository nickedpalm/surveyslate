<link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />
<script is:inline src="/vendor/leaflet/leaflet.js"></script>
<script is:inline>
  function initListingPage() {
    // Map
    var el = document.getElementById('listing-map');
    if (el && !el.dataset.init) {
      el.dataset.init = 'true';
      var lat = parseFloat(el.dataset.lat);
      var lng = parseFloat(el.dataset.lng);
      var name = el.dataset.name;
      var map = L.map(el).setView([lat, lng], 14);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);
      L.marker([lat, lng]).addTo(map).bindPopup(name).openPopup();
    }

    // Provider view toggle
    var params = new URLSearchParams(window.location.search);
    var isProvider = params.get('claim') === 'true' || params.get('src') === 'provider';

    if (isProvider) {
      document.querySelectorAll('.provider-only').forEach(function(el) { el.classList.remove('hidden'); });
      var providerView = document.getElementById('provider-view');
      if (providerView) providerView.classList.remove('hidden');
      var badge = document.getElementById('verified-badge');
      if (badge) badge.classList.add('hidden');
      // Hide attorney-facing "Also in City" to avoid duplicate with competitor peek
      var alsoInCity = document.getElementById('also-in-city');
      if (alsoInCity) alsoInCity.classList.add('hidden');
    }

    // HTML escape helper for live-patch
    function _esc(str) {
      var d = document.createElement('div');
      d.textContent = str || '';
      return d.innerHTML;
    }

    // Live-patch claimed listing data from D1
    var slug = window.location.pathname.replace(/^\/listing\//, '').replace(/\/$/, '');
    if (slug) {
      fetch('/api/listing/' + encodeURIComponent(slug))
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(d) {
          if (!d || !d.claimed) return;
          var data = d.data || {};

          // Patch description
          if (data.description) {
            var descEl = document.getElementById('listing-description');
            if (descEl) descEl.textContent = data.description;
          }

          // Patch phone
          if (data.phone) {
            var phoneEl = document.querySelector('.btn-phone');
            if (phoneEl) {
              phoneEl.href = 'tel:' + encodeURIComponent(data.phone);
              phoneEl.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg> ' + _esc(data.phone);
            }
          }

          // Patch website
          if (data.website) {
            var siteEl = document.querySelector('.btn-outline');
            if (siteEl && siteEl.textContent.trim() === 'Visit Website') {
              siteEl.href = data.website;
            }
          }

          // Patch services
          if (data.services && data.services.length > 0) {
            var svcWrap = document.getElementById('listing-services');
            if (svcWrap) {
              svcWrap.innerHTML = data.services.map(function(s) {
                return '<span class="tag active">' + _esc(s) + '</span>';
              }).join('');
            }
          }

          // Patch certifications
          if (data.certifications && data.certifications.length > 0) {
            var certEl = document.getElementById('listing-certifications');
            if (certEl) {
              certEl.textContent = data.certifications.join(', ');
            }
          }

          // Show verified badge for claimed listings
          if (!isProvider) {
            var vBadge = document.getElementById('verified-badge');
            if (vBadge) {
              vBadge.querySelector('span').innerHTML = 'Claimed & verified by owner';
              vBadge.classList.remove('hidden');
            }
          }

          // Render photos if available
          if (d.photos && d.photos.length > 0) {
            var gallerySlot = document.getElementById('photo-gallery-slot');
            if (gallerySlot) {
              var photoHtml = '<div class="photo-gallery">' +
                '<h2><svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg> Photos &amp; Portfolio</h2>' +
                '<div class="gallery-grid">' +
                d.photos.map(function(p) {
                  return '<img src="' + _esc(p.url) + '" alt="' + _esc(p.filename || 'Photo') + '" loading="lazy" />';
                }).join('') +
                '</div></div>';
              gallerySlot.innerHTML = photoHtml;
            }
          }
        })
        .catch(function() {});
    }
  }

  document.addEventListener('astro:page-load', initListingPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initListingPage);
  } else {
    initListingPage();
  }

  // Page view tracking
  function trackView() {
    const slug = document.querySelector('[data-listing-slug]')?.dataset.listingSlug;
    if (slug && navigator.sendBeacon) {
      navigator.sendBeacon('/api/track?s=' + encodeURIComponent(slug) + '&p=' + encodeURIComponent(location.pathname));
    }
  }
  document.addEventListener('astro:page-load', trackView);
  if (document.readyState !== 'loading') trackView();
</script>

<!-- Contact Gate Modal (for unclaimed listings) -->
<div id="contact-gate-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm" style="display:none;">
  <div class="bg-white rounded-xl shadow-2xl max-w-sm w-full mx-4 p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-1">Get contact info</h3>
    <p class="text-sm text-gray-500 mb-4">Enter your email to reveal this provider's direct contact details.</p>
    <form id="contact-gate-form" class="space-y-3">
      <input type="email" name="email" required placeholder="your@email.com" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-4 rounded-lg text-sm transition-colors">
        Reveal Contact Info
      </button>
    </form>
    <p class="text-xs text-gray-400 mt-3 text-center">We'll add you to our newsletter. Unsubscribe anytime.</p>
    <button id="contact-gate-close" class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 text-xl leading-none" aria-label="Close">&times;</button>
  </div>
</div>

<script is:inline>
(function() {
  function initContactGate() {
    var modal = document.getElementById('contact-gate-modal');
    var form = document.getElementById('contact-gate-form');
    var closeBtn = document.getElementById('contact-gate-close');
    if (!modal || !form) return;

    var pendingBtn = null;
    var GATE_KEY = 'df_contact_unlocked';

    // Check if already unlocked
    function isUnlocked() {
      try { return localStorage.getItem(GATE_KEY) === '1'; } catch(e) { return false; }
    }

    // Reveal all gated buttons on page
    function revealAll() {
      document.querySelectorAll('.contact-gate-btn').forEach(function(btn) {
        var type = btn.getAttribute('data-gate-type');
        var value = btn.getAttribute('data-gate-value');
        if (type === 'phone') {
          var link = document.createElement('a');
          link.href = 'tel:' + value;
          link.className = btn.className.replace('contact-gate-btn', '');
          link.innerHTML = btn.querySelector('svg')?.outerHTML + ' ' + value;
          btn.replaceWith(link);
        } else if (type === 'website') {
          var link = document.createElement('a');
          link.href = value;
          link.target = '_blank';
          link.rel = 'noopener noreferrer';
          link.className = btn.className.replace('contact-gate-btn', '');
          link.textContent = 'Visit Website';
          btn.replaceWith(link);
        }
      });
    }

    // If already unlocked, reveal immediately
    if (isUnlocked()) { revealAll(); return; }

    // Click handler for gated buttons
    document.querySelectorAll('.contact-gate-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        pendingBtn = btn;
        modal.style.display = 'flex';
        modal.classList.remove('hidden');
        modal.querySelector('input[name="email"]')?.focus();
      });
    });

    // Close modal
    if (closeBtn) closeBtn.addEventListener('click', function() {
      modal.style.display = 'none';
      modal.classList.add('hidden');
    });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) { modal.style.display = 'none'; modal.classList.add('hidden'); }
    });

    // Form submit
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = form.querySelector('input[name="email"]').value.trim();
      if (!email) return;

      var btn = form.querySelector('button[type="submit"]');
      btn.textContent = 'Unlocking...';
      btn.disabled = true;

      // Subscribe to newsletter
      fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, list_id: 6 })
      }).finally(function() {
        try { localStorage.setItem(GATE_KEY, '1'); } catch(e) {}
        modal.style.display = 'none';
        modal.classList.add('hidden');
        revealAll();
      });
    });
  }

  document.addEventListener('astro:page-load', initContactGate);
  if (document.readyState !== 'loading') initContactGate();
})();
</script>
