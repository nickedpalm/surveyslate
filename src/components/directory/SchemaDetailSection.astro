---
import type { SchemaField } from '~/config';

interface Props {
  schema: SchemaField[];
  values: Record<string, unknown>;
}

const { schema, values } = Astro.props;

const populated = schema.filter((f) => {
  const v = values[f.key];
  if (v == null) return false;
  if (Array.isArray(v) && v.length === 0) return false;
  if (v === '') return false;
  return true;
});
---

{populated.length > 0 && (
  <section class="schema-details mt-8 pt-6 border-t border-gray-200">
    <h2 class="text-lg font-semibold mb-4">Additional Details</h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 text-sm">
      {populated.map((field) => {
        const raw = values[field.key];
        const pagefindValue = Array.isArray(raw) ? raw.join(',') : String(raw);
        return (
          <div class="flex flex-col" data-pagefind-filter={`${field.key}:${pagefindValue}`}>
            <dt class="font-medium text-gray-500">{field.label}</dt>
            <dd class="text-gray-900">
              {field.display === 'badge' && field.type === 'boolean' && (
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-primary-50 text-primary-700">
                  {raw === true ? 'Yes' : 'No'}
                </span>
              )}
              {field.display === 'pill_list' && Array.isArray(raw) && (
                <span class="flex flex-wrap gap-1">
                  {raw.map((v) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-700">
                      {String(v)}
                    </span>
                  ))}
                </span>
              )}
              {field.display === 'range' && (
                <span>{String(raw)}{field.unit ? ` ${field.unit}` : ''}</span>
              )}
              {field.display === 'link' && typeof raw === 'string' && (
                <a href={raw} class="text-primary-600 hover:underline" target="_blank" rel="noopener">
                  {raw}
                </a>
              )}
              {(!field.display || field.display === 'text') && (
                <span>{Array.isArray(raw) ? raw.join(', ') : String(raw)}</span>
              )}
            </dd>
          </div>
        );
      })}
    </dl>
  </section>
)}
