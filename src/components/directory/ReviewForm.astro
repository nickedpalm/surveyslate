---
import Turnstile from '~/components/common/Turnstile.astro';
import config from '~/config';

interface Props {
  listingSlug: string;
  listingName: string;
}

const { listingSlug, listingName } = Astro.props;
---
<div class="card-section" id="review-form-card">
  <h3 class="text-base font-bold mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
    Leave a Review for {listingName}
  </h3>
  <form id="review-form" class="flex flex-col gap-3.5">
    <input type="hidden" name="provider_slug" value={listingSlug} />
    <!-- Honeypot -->
    <div class="absolute -left-[9999px]" aria-hidden="true">
      <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
    </div>
    <div>
      <label class="block text-[13px] font-semibold mb-1.5 text-gray-700">Your Rating</label>
      <div class="flex gap-1" id="star-picker">
        {[1, 2, 3, 4, 5].map((n) => (
          <button type="button" data-rating={n} class="star-btn w-10 h-10 rounded-lg border border-gray-200 flex items-center justify-center text-xl text-gray-300 hover:text-yellow-400 hover:border-yellow-400 transition-colors" aria-label={`${n} star${n > 1 ? 's' : ''}`}>
            ★
          </button>
        ))}
      </div>
      <input type="hidden" name="rating" id="review-rating" value="" required />
    </div>
    <div>
      <label for="reviewer_name" class="block text-[13px] font-semibold mb-1.5 text-gray-700">Your Name</label>
      <input type="text" id="reviewer_name" name="reviewer_name" required placeholder="Full name" class="w-full border-[1.5px] border-gray-300 rounded-[10px] px-3.5 py-2.5 text-sm font-sans transition-colors focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-600/15" />
    </div>
    <div>
      <label for="reviewer_email" class="block text-[13px] font-semibold mb-1.5 text-gray-700">Email <span style="color:#9ca3af; font-weight:400;">(not published)</span></label>
      <input type="email" id="reviewer_email" name="reviewer_email" required placeholder="you@firm.com" class="w-full border-[1.5px] border-gray-300 rounded-[10px] px-3.5 py-2.5 text-sm font-sans transition-colors focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-600/15" />
    </div>
    <div>
      <label for="review_comment" class="block text-[13px] font-semibold mb-1.5 text-gray-700">Your Review</label>
      <textarea id="review_comment" name="comment" rows="4" required placeholder="How was your experience working with this provider?" class="w-full border-[1.5px] border-gray-300 rounded-[10px] px-3.5 py-2.5 text-sm font-sans transition-colors focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-600/15 resize-y min-h-[100px]"></textarea>
    </div>
    <div class="cf-turnstile" data-sitekey={config.turnsiteSitekey} data-theme="light"></div>
    <button type="submit" class="btn-action-primary w-full" id="review-submit-btn">
      Submit Review
    </button>
    <p class="text-center text-xs text-gray-500 mt-1">Reviews are verified before publishing.</p>
  </form>

  <!-- Success state -->
  <div id="review-success" class="hidden text-center py-6">
    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
      <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>
    <h3 class="text-lg font-semibold text-gray-900">Review Submitted!</h3>
    <p class="text-sm text-gray-600 mt-1">Thank you for your feedback. Your review will be published after verification.</p>
  </div>

  <!-- Error state -->
  <div id="review-error" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 mt-3">
    <p class="text-sm text-red-700" id="review-error-msg">Something went wrong. Please try again.</p>
  </div>
</div>

<script is:inline>
  function initReviewForm() {
    const form = document.getElementById('review-form');
    if (!form || form.dataset.init) return;
    form.dataset.init = 'true';

    let selectedRating = 0;
    const ratingInput = document.getElementById('review-rating');
    const starBtns = form.querySelectorAll('.star-btn');

    starBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        selectedRating = parseInt(btn.dataset.rating);
        ratingInput.value = selectedRating;
        starBtns.forEach(b => {
          const r = parseInt(b.dataset.rating);
          if (r <= selectedRating) {
            b.classList.remove('text-gray-300', 'border-gray-200');
            b.classList.add('text-yellow-400', 'border-yellow-400', 'bg-yellow-50');
          } else {
            b.classList.add('text-gray-300', 'border-gray-200');
            b.classList.remove('text-yellow-400', 'border-yellow-400', 'bg-yellow-50');
          }
        });
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('review-submit-btn');
      const errorDiv = document.getElementById('review-error');
      const successDiv = document.getElementById('review-success');
      errorDiv.classList.add('hidden');

      if (!selectedRating) {
        document.getElementById('review-error-msg').textContent = 'Please select a star rating.';
        errorDiv.classList.remove('hidden');
        return;
      }

      // Honeypot
      if (form.website_url.value) return;

      btn.disabled = true;
      btn.textContent = 'Submitting...';

      const turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
      const data = {
        provider_slug: form.provider_slug.value,
        reviewer_name: form.reviewer_name.value,
        reviewer_email: form.reviewer_email.value,
        rating: selectedRating,
        comment: form.comment.value,
        turnstile_token: turnstileInput ? turnstileInput.value : '',
      };

      try {
        const resp = await fetch('/api/reviews', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!resp.ok) {
          const err = await resp.json().catch(() => ({}));
          throw new Error(err.error || 'Request failed');
        }
        form.classList.add('hidden');
        successDiv.classList.remove('hidden');
      } catch (err) {
        document.getElementById('review-error-msg').textContent = err.message || 'Something went wrong. Please try again.';
        errorDiv.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Submit Review';
        if (window.turnstile) turnstile.reset();
      }
    });
  }
  document.addEventListener('astro:page-load', initReviewForm);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReviewForm);
  } else {
    initReviewForm();
  }
</script>
<Turnstile />
