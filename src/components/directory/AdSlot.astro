---
import config from '~/config';

interface Props {
  placement: 'city-top' | 'city-sidebar' | 'listing-bottom' | 'search';
  city?: string;
  state?: string;
}

const { placement, city, state } = Astro.props;

const cta = {
  'city-top': `Promote your ${config.primaryKeyword} business in ${city || 'this city'}`,
  'city-sidebar': `Get more visibility in ${city || 'this area'}`,
  'listing-bottom': `Want to appear above your competitors?`,
  'search': `Reach customers searching for ${config.primaryKeyword}s`,
};

const mailto = `mailto:advertise@${config.domain}?subject=${encodeURIComponent(`Advertising inquiry — ${placement} in ${city || 'directory'}, ${state || ''}`)}`;
---
<div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center bg-gray-50/50">
  <p class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-1">Sponsored</p>
  <p class="text-gray-700 font-medium">{cta[placement]}</p>
  <a href={mailto} class="inline-flex items-center gap-2 mt-3 px-4 py-2 bg-primary-600 text-white text-sm font-semibold rounded-lg hover:bg-primary-700 transition-colors no-underline">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
    Get Featured
  </a>
  <p class="text-xs text-gray-400 mt-2">Premium placement &middot; Priority visibility &middot; Verified badge</p>
</div>
