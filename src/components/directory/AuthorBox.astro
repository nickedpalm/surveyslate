---
import config from '~/config';
const author = config.editorialAuthor;
---
<div class="not-prose mt-10 border-t border-gray-200 pt-8">
  <div class="flex items-start gap-4">
    <div class="w-14 h-14 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 font-bold text-xl flex-shrink-0">
      {author.name.charAt(0)}
    </div>
    <div>
      <p class="text-sm text-gray-500 uppercase tracking-wide font-medium">About the Author</p>
      <p class="font-semibold text-gray-900 mt-1">{author.name}</p>
      <p class="text-sm text-gray-500">{author.title}</p>
      <p class="text-sm text-gray-600 mt-2">{author.bio}</p>
      <div class="flex items-center gap-3 mt-2">
        {author.linkedin && (
          <a href={author.linkedin} class="text-sm text-primary-600 hover:underline" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        )}
        <a href="/about/" class="text-sm text-primary-600 hover:underline">More about us</a>
      </div>
    </div>
  </div>
</div>
