---
import SentimentBadge from './SentimentBadge.astro';

interface Highlight {
  text: string;
  sentiment: 'positive' | 'negative';
}

interface Props {
  label: 'positive' | 'mixed' | 'negative';
  score: number;
  keywords: string[];
  highlights: Highlight[];
  summary: string;
}

const { label, score, keywords, highlights, summary } = Astro.props;
---
<div class="card p-5 space-y-4">
  <div class="flex items-center justify-between">
    <h3 class="font-semibold text-gray-900">Review Sentiment</h3>
    <SentimentBadge label={label} score={score} />
  </div>

  {summary && (
    <p class="text-sm text-gray-600">{summary}</p>
  )}

  {keywords.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {keywords.map((kw) => (
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">{kw}</span>
      ))}
    </div>
  )}

  {highlights.length > 0 && (
    <div class="space-y-3">
      <h4 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Review Highlights</h4>
      {highlights.map((h) => (
        <blockquote class={`text-sm border-l-3 pl-3 py-1 ${
          h.sentiment === 'positive'
            ? 'border-emerald-400 text-gray-700'
            : 'border-red-400 text-gray-700'
        }`}>
          <p>"{h.text}"</p>
        </blockquote>
      ))}
    </div>
  )}
</div>
