---
import PageLayout from '~/layouts/PageLayout.astro';
import config from '~/config';
import { getAllListings } from '~/lib/listings';

const metadata = { title: `Provider Login — ${config.brandName}`, description: `Log in to manage your ${config.brandName} listing.` };

// Pre-build a slug→name map so client JS can display the business name
const listings = getAllListings();
const listingMap: Record<string, string> = {};
for (const l of listings) {
  listingMap[l.slug] = l.name;
}
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <div class="min-h-[70vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="w-14 h-14 bg-primary-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Claim Your Listing</h1>
        <p id="claim-subtitle" class="text-gray-500 text-sm mt-2">Verify your email to claim and manage this listing.</p>
        <!-- Listing name banner (shown when ?listing= param present) -->
        <div id="listing-name-banner" class="hidden mt-3 inline-flex items-center gap-2 bg-blue-50 border border-blue-200 text-blue-800 text-sm font-medium px-4 py-2 rounded-xl">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <span id="listing-name-text"></span>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <form id="login-form" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Business email</label>
            <input type="email" id="email" name="email" required placeholder="you@yourbusiness.com"
              class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
          </div>
          <input type="hidden" id="listing-slug" name="listing_slug" />
          <button type="submit" id="submit-btn"
            class="w-full bg-primary-600 hover:bg-primary-500 text-white font-semibold py-3 rounded-xl transition-colors text-sm">
            Send Login Link
          </button>
        </form>

        <div id="success-msg" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-xl text-sm text-green-800 text-center" role="status" aria-live="polite">
          <p class="font-semibold">Check your inbox</p>
          <p class="mt-1 text-green-600">We sent a login link. It expires in 15 minutes.</p>
        </div>

        <div id="error-msg" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 text-center" role="alert" aria-live="assertive"></div>
      </div>

      <div class="mt-6 text-center">
        <p class="text-xs text-gray-400">No password needed. We'll email you a secure login link.</p>
      </div>

      <!-- What you get -->
      <div class="mt-8 space-y-3">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider text-center">What claiming gets you</h2>
        <div class="grid grid-cols-1 gap-2">
          <div class="flex items-center gap-3 bg-green-50 border border-green-100 rounded-xl px-4 py-3">
            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm text-gray-800">Update your business info, hours, and services</span>
          </div>
          <div class="flex items-center gap-3 bg-green-50 border border-green-100 rounded-xl px-4 py-3">
            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm text-gray-800">Receive and respond to quote requests from {config.buyerPersona}</span>
          </div>
          <div class="flex items-center gap-3 bg-green-50 border border-green-100 rounded-xl px-4 py-3">
            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm text-gray-800">Get a verified badge on your listing</span>
          </div>
        </div>
      </div>

      <!-- How it works -->
      <div class="mt-8 space-y-4">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider text-center">How claiming works</h2>
        <div class="grid grid-cols-1 gap-3">
          <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-4">
            <span class="w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold flex items-center justify-center flex-shrink-0">1</span>
            <div><p class="text-sm font-medium text-gray-900">Enter your email</p><p class="text-xs text-gray-500 mt-0.5">Use the email associated with your business.</p></div>
          </div>
          <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-4">
            <span class="w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold flex items-center justify-center flex-shrink-0">2</span>
            <div><p class="text-sm font-medium text-gray-900">Click the link in your email</p><p class="text-xs text-gray-500 mt-0.5">We'll send a secure, one-time login link.</p></div>
          </div>
          <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-4">
            <span class="w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold flex items-center justify-center flex-shrink-0">3</span>
            <div><p class="text-sm font-medium text-gray-900">Manage your listing</p><p class="text-xs text-gray-500 mt-0.5">Update info, view leads, and respond to quote requests.</p></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ listingMap }}>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var listingSlug = params.get('listing');
      var errorParam = params.get('error');

      if (listingSlug) {
        document.getElementById('listing-slug').value = listingSlug;

        // Show the business name being claimed
        var name = listingMap[listingSlug];
        if (name) {
          var banner = document.getElementById('listing-name-banner');
          var nameText = document.getElementById('listing-name-text');
          nameText.textContent = name;
          banner.classList.remove('hidden');
          document.getElementById('claim-subtitle').textContent =
            'Verify your email to claim and manage this listing.';
        }
      }

      if (errorParam) {
        var errEl = document.getElementById('error-msg');
        errEl.textContent = errorParam;
        errEl.classList.remove('hidden');
      }

      var form = document.getElementById('login-form');
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var btn = document.getElementById('submit-btn');
        var successEl = document.getElementById('success-msg');
        var errorEl = document.getElementById('error-msg');

        successEl.classList.add('hidden');
        errorEl.classList.add('hidden');

        var email = document.getElementById('email').value.trim();
        var slug = document.getElementById('listing-slug').value;

        btn.textContent = 'Sending...';
        btn.disabled = true;

        try {
          var resp = await fetch('/api/auth/magic-link', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ email: email, listing_slug: slug || undefined }),
          });

          var data = await resp.json();

          if (resp.ok) {
            successEl.classList.remove('hidden');
            form.classList.add('hidden');
          } else {
            errorEl.textContent = data.error || 'Something went wrong.';
            errorEl.classList.remove('hidden');
          }
        } catch (err) {
          errorEl.textContent = 'Network error. Please try again.';
          errorEl.classList.remove('hidden');
        } finally {
          btn.textContent = 'Send Login Link';
          btn.disabled = false;
        }
      });

      // Check if already logged in
      fetch('/api/auth/session', { credentials: 'include' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.authenticated) {
            var target = listingSlug ? '/provider/dashboard?listing=' + listingSlug : '/provider/dashboard';
            window.location.href = target;
          }
        })
        .catch(function() {});
    })();
  </script>
</PageLayout>
