---
import DashboardLayout from '~/layouts/DashboardLayout.astro';
import config from '~/config';
---
<DashboardLayout title={`Service Area — ${config.brandName}`} activePage="service-area">

  <div class="dash-topbar">
    <div>
      <h1>Service Area</h1>
      <div class="dash-topbar-sub">Define where you provide {config.servicePhrase}.</div>
    </div>
    <button id="save-area-btn" class="dash-btn dash-btn-primary">Save Changes</button>
  </div>

  <div id="save-area-banner" style="display:none;background:#ecfdf5;border:1px solid #a7f3d0;color:#065f46;padding:12px 20px;border-radius:12px;font-size:14px;font-weight:600;margin-bottom:20px;text-align:center"></div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px">
    <!-- Primary location -->
    <div class="dash-card">
      <div class="dash-card-header"><h2>Primary Location</h2></div>
      <div class="dash-card-body">
        <div style="display:flex;flex-direction:column;gap:14px">
          <div>
            <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:6px">Coverage Area Description</label>
            <input type="text" id="area-coverage" class="dash-input" placeholder="e.g., Greater New York City metro" />
          </div>
          <div>
            <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:6px">City / State</label>
            <input type="text" id="area-location" class="dash-input" placeholder="e.g., New York, NY" readonly style="background:#f9fafb" />
          </div>
        </div>
      </div>
    </div>

    <!-- Service radius -->
    <div class="dash-card">
      <div class="dash-card-header"><h2>Service Radius</h2></div>
      <div class="dash-card-body" style="text-align:center">
        <div style="font-size:48px;font-weight:800;color:#2563eb;margin-bottom:8px" id="radius-display">60</div>
        <div style="font-size:14px;color:#6b7280;margin-bottom:20px">miles</div>
        <input type="range" id="radius-slider" min="10" max="150" value="60" style="width:100%;accent-color:#2563eb" />
        <div style="display:flex;justify-content:space-between;font-size:11px;color:#9ca3af;margin-top:4px">
          <span>10 mi</span><span>150 mi</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Availability -->
  <div class="dash-card" style="margin-bottom:20px">
    <div class="dash-card-header"><h2>Availability</h2></div>
    <div class="dash-card-body">
      <div style="display:flex;gap:8px;margin-bottom:20px">
        <button class="day-btn active" data-day="mon" style="flex:1;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#2563eb;color:#fff;border:none;cursor:pointer">Mon</button>
        <button class="day-btn active" data-day="tue" style="flex:1;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#2563eb;color:#fff;border:none;cursor:pointer">Tue</button>
        <button class="day-btn active" data-day="wed" style="flex:1;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#2563eb;color:#fff;border:none;cursor:pointer">Wed</button>
        <button class="day-btn active" data-day="thu" style="flex:1;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#2563eb;color:#fff;border:none;cursor:pointer">Thu</button>
        <button class="day-btn active" data-day="fri" style="flex:1;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#2563eb;color:#fff;border:none;cursor:pointer">Fri</button>
        <button class="day-btn" data-day="sat" style="flex:1;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#f3f4f6;color:#6b7280;border:none;cursor:pointer">Sat</button>
        <button class="day-btn" data-day="sun" style="flex:1;padding:10px;border-radius:8px;font-size:13px;font-weight:600;background:#f3f4f6;color:#6b7280;border:none;cursor:pointer">Sun</button>
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-top:1px solid #f3f4f6">
        <div>
          <div style="font-size:14px;font-weight:600;color:#1a1a2e">Rush availability</div>
          <div style="font-size:12px;color:#6b7280">Accept last-minute bookings (< 48 hours notice)</div>
        </div>
        <label class="dash-toggle"><input type="checkbox" id="rush-toggle" /><span class="dash-toggle-slider"></span></label>
      </div>
      <div style="background:#eff6ff;border-radius:10px;padding:12px 16px;margin-top:12px">
        <p style="font-size:12px;color:#1e40af;font-weight:500">&#x1f4a1; Providers with rush availability get <strong>40% more quote requests</strong> on average.</p>
      </div>
    </div>
  </div>

  <!-- Travel policy -->
  <div class="dash-card">
    <div class="dash-card-header"><h2>Travel Policy</h2></div>
    <div class="dash-card-body">
      <textarea id="travel-policy" class="dash-input" rows="4" placeholder="Describe your travel policy. E.g., 'Travel within 60 miles included. Mileage fee of $0.65/mile beyond that. Overnight travel available with advance notice.'"></textarea>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-top:14px">
        <div style="font-size:13px;color:#374151;font-weight:500">Show travel policy on listing</div>
        <label class="dash-toggle"><input type="checkbox" checked /><span class="dash-toggle-slider"></span></label>
      </div>
    </div>
  </div>

  <script is:inline>
    window.addEventListener('dash-ready', async function() {
      var slug = window.dashState.currentSlug;

      // Load existing data
      try {
        var resp = await fetch('/api/provider/listing?slug=' + slug, { credentials: 'include' });
        if (resp.ok) {
          var result = await resp.json();
          var d = result.data || {};
          if (d.coverage_area) document.getElementById('area-coverage').value = d.coverage_area;
          if (d.service_radius) {
            document.getElementById('radius-slider').value = d.service_radius;
            document.getElementById('radius-display').textContent = d.service_radius;
          }
          if (d.rush_available) document.getElementById('rush-toggle').checked = true;
          if (d.travel_policy) document.getElementById('travel-policy').value = d.travel_policy;
          // Populate city/state from listing data
          var cityState = [d.city, d.state].filter(Boolean).join(', ');
          if (cityState) document.getElementById('area-location').value = cityState;
          if (d.availability_days && Array.isArray(d.availability_days)) {
            document.querySelectorAll('.day-btn').forEach(function(btn) {
              var day = btn.getAttribute('data-day');
              var active = d.availability_days.indexOf(day) !== -1;
              if (active) {
                btn.classList.add('active');
                btn.style.background = '#2563eb'; btn.style.color = '#fff';
              } else {
                btn.classList.remove('active');
                btn.style.background = '#f3f4f6'; btn.style.color = '#6b7280';
              }
            });
          }
        }
      } catch(e) {}

      // Radius slider
      var slider = document.getElementById('radius-slider');
      var display = document.getElementById('radius-display');
      slider.addEventListener('input', function() { display.textContent = this.value; });

      // Day toggles
      document.querySelectorAll('.day-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          this.classList.toggle('active');
          if (this.classList.contains('active')) {
            this.style.background = '#2563eb'; this.style.color = '#fff';
          } else {
            this.style.background = '#f3f4f6'; this.style.color = '#6b7280';
          }
        });
      });

      // Save — all fields
      document.getElementById('save-area-btn').addEventListener('click', async function() {
        var btn = this;
        var banner = document.getElementById('save-area-banner');
        btn.textContent = 'Saving...'; btn.disabled = true;

        var activeDays = [];
        document.querySelectorAll('.day-btn.active').forEach(function(b) {
          activeDays.push(b.getAttribute('data-day'));
        });

        var payload = {
          slug: slug,
          coverage_area: document.getElementById('area-coverage').value.trim(),
          service_radius: parseInt(document.getElementById('radius-slider').value),
          availability_days: activeDays,
          rush_available: document.getElementById('rush-toggle').checked,
          travel_policy: document.getElementById('travel-policy').value.trim(),
        };

        try {
          var resp = await fetch('/api/provider/listing', { method:'PUT', headers:{'Content-Type':'application/json'}, credentials:'include', body:JSON.stringify(payload) });
          if (resp.ok) {
            banner.textContent = 'Service area saved!';
            banner.style.background = '#ecfdf5'; banner.style.color = '#065f46'; banner.style.border = '1px solid #a7f3d0';
            banner.style.display = 'block';
            setTimeout(function() { banner.style.display = 'none'; }, 3000);
          } else {
            banner.textContent = 'Failed to save. Please try again.';
            banner.style.background = '#fef2f2'; banner.style.color = '#991b1b'; banner.style.border = '1px solid #fecaca';
            banner.style.display = 'block';
            setTimeout(function() { banner.style.display = 'none'; }, 4000);
          }
        } catch(e) {
          banner.textContent = 'Network error. Please try again.';
          banner.style.background = '#fef2f2'; banner.style.color = '#991b1b'; banner.style.border = '1px solid #fecaca';
          banner.style.display = 'block';
          setTimeout(function() { banner.style.display = 'none'; }, 4000);
        }
        btn.textContent = 'Save Changes'; btn.disabled = false;
      });
    });
  </script>

</DashboardLayout>
