---
import PageLayout from '~/layouts/PageLayout.astro';
import config from '~/config';

const metadata = {
  title: `Verify Your Business — ${config.brandName}`,
  description: `Enter the verification code sent to your phone to claim your ${config.brandName} listing.`,
  robots: { index: false, follow: false },
};
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <div class="min-h-[70vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="w-14 h-14 bg-primary-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Verify Your Business</h1>
        <p id="phone-subtitle" class="text-gray-500 text-sm mt-2">We sent a 6-digit code to your phone.</p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <form id="verify-form" class="space-y-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-3 text-center">Enter verification code</label>
            <div id="code-inputs" class="flex justify-center gap-2" role="group" aria-label="Verification code">
              <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" data-idx="0" autocomplete="one-time-code" aria-label="Digit 1 of 6"
                class="w-12 h-14 text-center text-xl font-semibold rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
              <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" data-idx="1" aria-label="Digit 2 of 6"
                class="w-12 h-14 text-center text-xl font-semibold rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
              <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" data-idx="2" aria-label="Digit 3 of 6"
                class="w-12 h-14 text-center text-xl font-semibold rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
              <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" data-idx="3" aria-label="Digit 4 of 6"
                class="w-12 h-14 text-center text-xl font-semibold rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
              <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" data-idx="4" aria-label="Digit 5 of 6"
                class="w-12 h-14 text-center text-xl font-semibold rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
              <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" data-idx="5" aria-label="Digit 6 of 6"
                class="w-12 h-14 text-center text-xl font-semibold rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
            </div>
          </div>
          <input type="hidden" id="listing-slug" name="listing_slug" />
          <button type="submit" id="submit-btn"
            class="w-full bg-primary-600 hover:bg-primary-500 text-white font-semibold py-3 rounded-xl transition-colors text-sm">
            Verify Code
          </button>
        </form>

        <div id="error-msg" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 text-center" role="alert" aria-live="assertive"></div>

        <div id="max-attempts-msg" class="hidden mt-4 p-4 bg-amber-50 border border-amber-200 rounded-xl text-sm text-amber-800 text-center">
          <p class="font-semibold">Your claim has been submitted for manual review.</p>
          <p class="mt-1 text-amber-600">We'll verify your ownership and get back to you.</p>
        </div>

        <div class="mt-5 flex flex-col items-center gap-2">
          <button id="resend-btn" type="button" class="text-sm text-primary-600 hover:text-primary-500 hover:underline">
            Didn't receive the code?
          </button>
          <button id="manual-review-btn" type="button" class="text-sm text-gray-400 hover:text-gray-600 hover:underline">
            Having trouble? Request manual review
          </button>
        </div>
      </div>

      <div class="mt-6 text-center">
        <p class="text-xs text-gray-400">The code expires in 10 minutes. Check your phone for an SMS.</p>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var listingSlug = params.get('listing') || '';
      var phoneLast2 = params.get('phone') || '';

      // Set hidden listing slug
      document.getElementById('listing-slug').value = listingSlug;

      // Show masked phone number
      if (phoneLast2) {
        document.getElementById('phone-subtitle').textContent =
          'We sent a 6-digit code to (XXX) XXX-\u2009**' + phoneLast2;
      }

      var inputs = document.querySelectorAll('#code-inputs input');
      var form = document.getElementById('verify-form');
      var submitBtn = document.getElementById('submit-btn');
      var errorEl = document.getElementById('error-msg');
      var maxAttemptsEl = document.getElementById('max-attempts-msg');
      var resendBtn = document.getElementById('resend-btn');
      var manualBtn = document.getElementById('manual-review-btn');

      // Auto-focus first input
      inputs[0].focus();

      // Input handling: auto-advance, backspace, paste
      inputs.forEach(function(input, idx) {
        input.addEventListener('input', function(e) {
          var val = this.value.replace(/[^0-9]/g, '');
          this.value = val.slice(0, 1);
          if (val && idx < inputs.length - 1) {
            inputs[idx + 1].focus();
          }
        });

        input.addEventListener('keydown', function(e) {
          if (e.key === 'Backspace' && !this.value && idx > 0) {
            inputs[idx - 1].focus();
            inputs[idx - 1].value = '';
          }
        });

        input.addEventListener('paste', function(e) {
          e.preventDefault();
          var pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '');
          if (pasted.length >= 6) {
            for (var i = 0; i < 6; i++) {
              inputs[i].value = pasted[i];
            }
            inputs[5].focus();
          }
        });
      });

      function getCode() {
        var code = '';
        inputs.forEach(function(input) { code += input.value; });
        return code;
      }

      function setLoading(loading) {
        submitBtn.disabled = loading;
        submitBtn.textContent = loading ? 'Verifying...' : 'Verify Code';
      }

      function showError(msg) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }

      function hideError() {
        errorEl.classList.add('hidden');
      }

      // Submit verification code
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        hideError();

        var code = getCode();
        if (code.length !== 6) {
          showError('Please enter all 6 digits.');
          return;
        }

        setLoading(true);

        try {
          var resp = await fetch('/api/auth/verify-phone', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ code: code, listing_slug: listingSlug }),
          });

          var data = await resp.json();

          if (resp.ok) {
            // Success — redirect to dashboard
            var target = listingSlug ? '/provider/dashboard?listing=' + listingSlug : '/provider/dashboard';
            window.location.href = target;
          } else if (resp.status === 429 || (data.max_attempts_exceeded)) {
            // Max attempts exceeded — show manual review message and redirect
            form.classList.add('hidden');
            resendBtn.classList.add('hidden');
            manualBtn.classList.add('hidden');
            maxAttemptsEl.classList.remove('hidden');
            setTimeout(function() {
              var pendingUrl = '/provider/claim-pending';
              if (listingSlug) pendingUrl += '?listing=' + listingSlug;
              window.location.href = pendingUrl;
            }, 3000);
          } else {
            var msg = data.error || 'Invalid code. Please try again.';
            if (data.attempts_remaining !== undefined) {
              msg += ' (' + data.attempts_remaining + ' attempt' + (data.attempts_remaining !== 1 ? 's' : '') + ' remaining)';
            }
            showError(msg);
            // Clear inputs for retry
            inputs.forEach(function(input) { input.value = ''; });
            inputs[0].focus();
          }
        } catch (err) {
          showError('Network error. Please try again.');
        } finally {
          setLoading(false);
        }
      });

      // Resend code
      resendBtn.addEventListener('click', async function() {
        hideError();
        resendBtn.textContent = 'Sending...';
        resendBtn.disabled = true;

        try {
          var resp = await fetch('/api/auth/resend-code', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ listing_slug: listingSlug }),
          });

          if (resp.ok) {
            resendBtn.textContent = 'Code sent!';
            setTimeout(function() {
              resendBtn.textContent = "Didn't receive the code?";
              resendBtn.disabled = false;
            }, 5000);
          } else {
            var data = await resp.json();
            showError(data.error || 'Could not resend code. Please try again.');
            resendBtn.textContent = "Didn't receive the code?";
            resendBtn.disabled = false;
          }
        } catch (err) {
          showError('Network error. Please try again.');
          resendBtn.textContent = "Didn't receive the code?";
          resendBtn.disabled = false;
        }
      });

      // Manual review request
      manualBtn.addEventListener('click', async function() {
        hideError();
        manualBtn.textContent = 'Requesting...';
        manualBtn.disabled = true;

        try {
          var resp = await fetch('/api/auth/manual-review', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ listing_slug: listingSlug }),
          });

          if (resp.ok) {
            var pendingUrl = '/provider/claim-pending';
            if (listingSlug) pendingUrl += '?listing=' + listingSlug;
            window.location.href = pendingUrl;
          } else {
            var data = await resp.json();
            showError(data.error || 'Could not submit review request.');
            manualBtn.textContent = 'Having trouble? Request manual review';
            manualBtn.disabled = false;
          }
        } catch (err) {
          showError('Network error. Please try again.');
          manualBtn.textContent = 'Having trouble? Request manual review';
          manualBtn.disabled = false;
        }
      });
    })();
  </script>
</PageLayout>
