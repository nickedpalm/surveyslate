<style is:global>
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  /* Progressive enhancement: default to visible so content is readable
     without JS (SEO crawlers, degraded connections, Playwright snapshots).
     When JS loads, `html.js` gets set; only then do we hide-until-scrolled.
     Also auto-reveal via CSS timer as a safety net (1.2s) in case the
     IntersectionObserver never fires (Safari bugs, JS errors, etc.). */
  .animate-on-scroll {
    opacity: 1;
    transform: none;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  html.js .animate-on-scroll:not(.is-visible) {
    opacity: 0;
    transform: translateY(20px);
    animation: scroll-reveal-fallback 0s 1.2s forwards;
  }
  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
    animation: none;
  }
  @keyframes scroll-reveal-fallback {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-on-scroll,
    html.js .animate-on-scroll:not(.is-visible) {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
