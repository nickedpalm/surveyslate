---
import PageLayout from '~/layouts/PageLayout.astro';
import Turnstile from '~/components/common/Turnstile.astro';
import NewsletterSignup from '~/components/directory/NewsletterSignup.astro';
import FAQSection from '~/components/directory/FAQSection.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import guidesData from '~/data/guides.json';
import { getCollection } from 'astro:content';
import { getListingCountByCity, getListingCountByState, getAllListings } from '~/lib/listings';
import { titleCase, articleFor, smartLower} from '~/utils/utils';

const pkTitle = titleCase(config.primaryKeyword || config.name);
const pkArticleCap = articleFor(config.primaryKeyword || config.name, true);

const cityCounts = getListingCountByCity();
const stateCounts = getListingCountByState();
const allListings = getAllListings();
const totalListings = allListings.length;
const totalCities = Object.keys(cityCounts).length;
const totalStates = Object.keys(stateCounts).length;

// Top cities sorted by listing count then population
const citiesWithCounts = citiesData
  .map(c => ({ ...c, listingCount: cityCounts[c.slug] || 0 }))
  .sort((a, b) => b.listingCount - a.listingCount || b.population - a.population);

const topCities = citiesWithCounts.slice(0, 48);

// All blog posts for homepage crawl discovery (direct links, not just /blog/ root)
const allBlogPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0));

// Aggregate states
const stateMap = new Map<string, { stateSlug: string; stateName: string; state: string; cityCount: number; listingCount: number }>();
for (const city of citiesData) {
  const existing = stateMap.get(city.state);
  if (existing) {
    existing.cityCount++;
    existing.listingCount += cityCounts[city.slug] || 0;
  } else {
    stateMap.set(city.state, {
      stateSlug: city.stateSlug,
      stateName: city.stateName,
      state: city.state,
      cityCount: 1,
      listingCount: cityCounts[city.slug] || 0,
    });
  }
}
const states = Array.from(stateMap.values()).sort((a, b) => a.stateName.localeCompare(b.stateName));

// Top-rated sponsored providers for spotlight
const sponsoredProviders = allListings
  .filter(l => l.featured)
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 3);

// Fallback to top-rated if no sponsored
const spotlightProviders = sponsoredProviders.length >= 3
  ? sponsoredProviders
  : allListings
      .filter(l => l.rating >= 4 && l.review_count > 0)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0) || (b.review_count || 0) - (a.review_count || 0))
      .slice(0, 3);

// Compute average rating across providers with reviews
const ratedListings = allListings.filter(l => l.rating > 0 && l.review_count > 0);
const avgRating = ratedListings.length > 0
  ? (ratedListings.reduce((sum, l) => sum + l.rating, 0) / ratedListings.length).toFixed(1)
  : '4.5';

const currentYear = new Date().getFullYear();

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: config.brandName,
    url: config.siteUrl,
    description: config.description,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${config.siteUrl}/search/?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: config.brandName,
    url: config.siteUrl,
    description: config.description,
    foundingDate: `${config.foundedYear}`,
    contactPoint: {
      '@type': 'ContactPoint',
      email: config.contactEmail,
      contactType: 'customer service',
    },
    sameAs: [],
  },
];

const metadata = {
  title: `Find ${config.name} Near You (${currentYear}) | ${config.brandName}`,
  ignoreTitleTemplate: true,
  description: config.description,
};
---
<PageLayout metadata={metadata} hero="dark">
  <Fragment slot="announcement"><span></span></Fragment>

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-primary-900 to-slate-900">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.15) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(255,255,255,0.1) 0%, transparent 50%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-32">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 mb-6 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-sm text-white/90 font-medium">{totalListings}+ curated providers nationwide</span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 tracking-tight">
          Find the Right<br class="hidden sm:block" />
          <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">{config.primaryKeyword || config.name}</span> — Fast
        </h1>
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto mb-10 leading-relaxed">
          {(config.tagline || `The most comprehensive directory of ${config.name}`).replace(/[.!?]*$/, '')}. Researched credentials, real reviews, and direct quote requests.
        </p>

        <!-- Search -->
        <div class="max-w-xl mx-auto mb-6">
          <form id="hero-search" class="flex gap-2">
            <div class="relative flex-1">
              <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <label for="hero-city-input" class="sr-only">Search by city or zip code</label>
              <input
                type="text"
                id="hero-city-input"
                placeholder="Enter your city or zip code..."
                autocomplete="off"
                class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-white text-slate-900 placeholder-slate-400 text-base focus:outline-none focus:ring-2 focus:ring-amber-400 shadow-lg"
              />
              <ul id="hero-suggestions" class="hidden absolute z-50 w-full mt-1 bg-white rounded-xl shadow-xl border border-slate-200 max-h-64 overflow-y-auto"></ul>
            </div>
            <button type="submit" class="px-6 py-3.5 bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold rounded-xl transition-colors shadow-lg whitespace-nowrap">
              Search
            </button>
          </form>
        </div>
        <p class="text-sm text-slate-400">Free to search. No account needed. <a href="/about/" class="text-amber-400 hover:text-amber-300 underline">Learn more</a></p>
      </div>
    </div>
    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- Stats Bar -->
  <section class="relative -mt-8 z-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-xl border border-slate-100 px-8 py-6 grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-extrabold text-primary-700" data-counter={totalListings}>0</div>
          <div class="text-sm text-slate-500 mt-1">Curated Providers</div>
        </div>
        <div>
          <div class="text-3xl font-extrabold text-primary-700" data-counter={totalCities}>0</div>
          <div class="text-sm text-slate-500 mt-1">Cities Covered</div>
        </div>
        <div>
          <div class="text-3xl font-extrabold text-primary-700" data-counter={totalStates}>0</div>
          <div class="text-sm text-slate-500 mt-1">States</div>
        </div>
        <div>
          <div class="text-3xl font-extrabold text-primary-700">100%</div>
          <div class="text-sm text-slate-500 mt-1">Free to Search</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-2">Simple Process</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center animate-on-scroll">
          <div class="w-16 h-16 rounded-2xl bg-primary-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <div class="text-xs font-bold text-primary-600 uppercase tracking-widest mb-2">Step 1</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Search Your City</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Enter your city or zip to see available {smartLower(config.name)} near you.</p>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="w-16 h-16 rounded-2xl bg-emerald-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div class="text-xs font-bold text-emerald-600 uppercase tracking-widest mb-2">Step 2</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Compare Providers</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Review credentials, {config.primaryCredential}, ratings, and real client reviews side by side.</p>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="w-16 h-16 rounded-2xl bg-amber-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <div class="text-xs font-bold text-amber-600 uppercase tracking-widest mb-2">Step 3</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Request a Quote</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Send your project details directly to one or multiple providers — no middleman, no spam.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-2">Why {config.brandName}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Built for {titleCase(config.buyerPersona || 'buyers')}</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 border-l-4 border-primary-500 shadow-sm animate-on-scroll">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-primary-100 flex-shrink-0 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 mb-1">{config.primaryCredential}, Front and Center</h3>
              <p class="text-sm text-slate-500 leading-relaxed">We surface {config.primaryCredential} on every listing so you're never guessing about qualifications.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border-l-4 border-emerald-500 shadow-sm animate-on-scroll">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-emerald-100 flex-shrink-0 flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 mb-1">Get a Quote in Under 2 Minutes</h3>
              <p class="text-sm text-slate-500 leading-relaxed">Submit a quote request directly from any listing page. Name, case type, date — the provider handles the rest.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border-l-4 border-amber-500 shadow-sm animate-on-scroll">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-amber-100 flex-shrink-0 flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 mb-1">Local Providers, No Travel Surcharges</h3>
              <p class="text-sm text-slate-500 leading-relaxed">Out-of-market providers add $100–300 in travel fees. {config.brandName} surfaces local options first so your client doesn't absorb that cost.</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 border-l-4 border-violet-500 shadow-sm animate-on-scroll">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-violet-100 flex-shrink-0 flex items-center justify-center">
              <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 mb-1">Real Reviews from Real {titleCase(config.buyerPersona || 'buyers')}</h3>
              <p class="text-sm text-slate-500 leading-relaxed">We aggregate real reviews and run sentiment analysis so you can see what other litigators actually think — not just a star rating.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Quote Intake -->
  <section class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-primary-50 to-white rounded-2xl border border-primary-100 shadow-lg p-8 animate-on-scroll">
        <div class="text-center mb-6">
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Need {pkArticleCap} {pkTitle} Fast?</h2>
          <p class="text-sm text-slate-500">Tell us when and where. We'll match you with qualified providers in your area.</p>
        </div>
        <form id="quick-quote-form" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div>
              <label for="qq-city" class="sr-only">City or Zip</label>
              <input type="text" id="qq-city" name="city" placeholder="City or zip code" required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
            </div>
            <div>
              <label for="qq-date" class="sr-only">Project Date</label>
              <input type="date" id="qq-date" name="date" required min={new Date().toISOString().split('T')[0]}
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-300 text-slate-500" />
            </div>
            <div>
              <label for="qq-email" class="sr-only">Your Email</label>
              <input type="email" id="qq-email" name="email" placeholder="Your email" required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-300" />
            </div>
          </div>
          <div class="hidden"><input type="text" name="fax_number" tabindex="-1" autocomplete="off" /></div>
          <div class="cf-turnstile" data-sitekey={config.turnsiteSitekey} data-theme="light"></div>
          <button type="submit" class="w-full bg-primary-600 hover:bg-primary-500 text-white font-bold py-3 rounded-xl transition-colors text-sm shadow-sm">
            Get Quotes from Providers Near Me &rarr;
          </button>
        </form>
        <p id="qq-success" class="hidden text-center text-sm text-green-700 mt-4 font-medium" role="status" aria-live="polite"></p>
        <p id="qq-error" class="hidden text-center text-sm text-red-600 mt-4" role="alert" aria-live="assertive"></p>
        <p class="text-center text-xs text-slate-400 mt-4">No spam, no obligation. We only share your info with matched providers.</p>
      </div>
    </div>
  </section>

  <!-- Sponsored Providers Spotlight -->
  {spotlightProviders.length > 0 && (
    <section class="py-20 bg-slate-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14 animate-on-scroll">
          <p class="text-sm font-semibold uppercase tracking-widest text-amber-600 mb-2">Top-Rated Providers</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Trusted by {titleCase(config.buyerPersona || 'buyers')} Nationwide</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {spotlightProviders.map((provider) => {
            const initials = provider.name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
            const stars = Math.round(provider.rating || 0);
            return (
              <a href={`/listing/${provider.slug}/`} class="group bg-white rounded-xl border border-slate-200 p-6 hover:shadow-lg hover:border-primary-300 transition-all no-underline animate-on-scroll">
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-sm">{initials}</div>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-bold text-slate-900 group-hover:text-primary-600 truncate transition-colors">{provider.name}</h3>
                    <p class="text-sm text-slate-500">{provider.city}, {provider.state}</p>
                  </div>
                </div>
                <div class="flex items-center gap-1 mb-3">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-4 h-4 ${i < stars ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                  <span class="text-xs text-slate-500 ml-1">({provider.review_count})</span>
                </div>
                {provider.certifications && provider.certifications.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {provider.certifications.slice(0, 3).map((cert) => (
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">{cert}</span>
                    ))}
                  </div>
                )}
                {provider.description && (
                  <p class="text-sm text-slate-500 line-clamp-2">{provider.description.slice(0, 120)}{provider.description.length > 120 ? '...' : ''}</p>
                )}
                <div class="mt-4 text-sm font-semibold text-primary-600 group-hover:text-primary-500 transition-colors">
                  View Profile &rarr;
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Social Proof / By the Numbers -->
  <section class="py-20 bg-gradient-to-br from-slate-900 via-primary-900 to-slate-900 text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <p class="text-sm font-semibold uppercase tracking-widest text-amber-400 mb-2">By the Numbers</p>
        <h2 class="text-3xl sm:text-4xl font-bold">Trusted by {titleCase(config.buyerPersona || 'buyers')} Nationwide</h2>
        <p class="text-white/60 text-sm mt-3 max-w-xl mx-auto">Real data from our curated provider network — updated with every listing.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6 text-center animate-on-scroll">
          <div class="w-12 h-12 rounded-full bg-primary-500/20 flex items-center justify-center mx-auto mb-4">
