  <!-- Quick Quote Script -->
  <script is:inline>
    function initQuickQuote() {
      const form = document.getElementById('quick-quote-form');
      if (!form || form.dataset.init) return;
      form.dataset.init = 'true';

      const success = document.getElementById('qq-success');
      const error = document.getElementById('qq-error');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        success.classList.add('hidden');
        error.classList.add('hidden');

        const data = Object.fromEntries(new FormData(form));
        if (data.fax_number) return;

        const btn = form.querySelector('button[type="submit"]');
        const origText = btn.textContent;
        btn.textContent = 'Sending...';
        btn.disabled = true;

        const turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
        try {
          const resp = await fetch('/api/leads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              providers: [],
              attorney_name: data.name || 'Quick Quote Request',
              attorney_email: data.email,
              attorney_phone: '',
              case_details: `Quick quote from homepage — needs a ${config.primaryKeyword || config.name} in ${data.city} on ${data.date}`,
              city: data.city,
              source: 'homepage-quick-quote',
              turnstile_token: turnstileInput ? turnstileInput.value : '',
            }),
          });

          if (resp.ok) {
            success.textContent = 'Request received! We\'ll connect you with providers in your area shortly.';
            success.classList.remove('hidden');
            form.reset();
          } else {
            throw new Error('Server error');
          }
        } catch {
          error.textContent = 'Something went wrong. Please try again or search for providers directly.';
          error.classList.remove('hidden');
          if (window.turnstile) turnstile.reset();
        } finally {
          btn.textContent = origText;
          btn.disabled = false;
        }
      });
    }
    document.addEventListener('astro:page-load', initQuickQuote);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initQuickQuote);
    } else {
      initQuickQuote();
    }
  </script>

  <!-- Hero Search Autocomplete -->
  <script is:inline>
    function initHeroSearch() {
      const input = document.getElementById('hero-city-input');
      const list = document.getElementById('hero-suggestions');
      const form = document.getElementById('hero-search');
      if (!input || !list || !form || form.dataset.init) return;
      form.dataset.init = 'true';

      let cities = [];
      fetch('/search/pagefind-entry.json').catch(() => {});

      // Load cities from inline data (includes lat/lng for zip geocoding)
      const cityData = JSON.parse(document.getElementById('city-data-full')?.textContent || '[]');
      cities = cityData;

      input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        if (q.length < 2) { list.classList.add('hidden'); return; }
        const matches = cities.filter(c =>
          c.city.toLowerCase().includes(q) || c.state.toLowerCase().includes(q)
        ).slice(0, 8);

        if (matches.length === 0) { list.classList.add('hidden'); return; }
        list.innerHTML = matches.map(c =>
          `<li><a href="/locations/${c.stateSlug}/${c.slug}/" class="block px-4 py-2.5 text-sm text-slate-700 hover:bg-primary-50 hover:text-primary-700 transition-colors">${c.city}, ${c.state} <span class="text-slate-400">(${c.count})</span></a></li>`
        ).join('');
        list.classList.remove('hidden');
      });

      document.addEventListener('click', (e) => {
        if (!input.contains(e.target) && !list.contains(e.target)) list.classList.add('hidden');
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const q = input.value.trim();
        const qLower = q.toLowerCase();
        const match = cities.find(c => c.city.toLowerCase() === qLower);
        if (match) {
          window.location.href = `/locations/${match.stateSlug}/${match.slug}/`;
          return;
        }
        // Zip code detection — geocode and redirect to nearest city
        if (/^\d{5}$/.test(q)) {
          const btn = form.querySelector('button[type="submit"]');
          btn.textContent = 'Finding...';
          btn.disabled = true;
          try {
            const resp = await fetch(`https://api.zippopotam.us/us/${q}`);
            if (resp.ok) {
              const data = await resp.json();
              const place = data.places?.[0];
              if (place) {
                const lat = parseFloat(place.latitude);
                const lng = parseFloat(place.longitude);
                // Find nearest city with lat/lng data (already loaded above)
                let best = null, bestDist = Infinity;
                for (const c of cities) {
                  const d = Math.sqrt((c.lat - lat) ** 2 + (c.lng - lng) ** 2);
                  if (d < bestDist) { bestDist = d; best = c; }
                }
                if (best) {
                  window.location.href = `/locations/${best.stateSlug}/${best.slug}/`;
                  return;
                }
              }
            }
          } catch {}
          btn.textContent = 'Search';
          btn.disabled = false;
        }
        if (q) {
          window.location.href = `/search/?q=${encodeURIComponent(q)}`;
        }
      });
    }
    document.addEventListener('astro:page-load', initHeroSearch);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroSearch);
    } else {
      initHeroSearch();
    }
  </script>

