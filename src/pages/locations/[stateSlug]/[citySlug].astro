      </div>
    )}
    {!Content && (
      <div class="mb-8">
        <NewsletterSignup variant="compact" city={cityInfo.city} />
      </div>
    )}

    {/* FAQ — accordion */}
    <FAQAccordion faqs={[
      {
        question: `How much does a ${config.primaryKeyword || smartLower(config.name)} cost in ${cityInfo.city}?`,
        answer: `${titleCase(config.primaryKeyword || config.name)} services in ${cityInfo.city} typically run ${config.jobValue || '$250-$1,500+'}, depending on scope, complexity, and turnaround requirements. Expedited work and specialized equipment add cost.`,
      },
      {
        question: `What should I look for in a ${config.primaryKeyword || smartLower(config.name)}?`,
        answer: `Look for ${config.primaryCredential} — it's the credential that separates qualified ${smartLower(config.name)} from the rest. Also verify insurance, check reviews, and confirm they can handle your project's specific requirements.`,
      },
      {
        question: `How many ${smartLower(config.name)} are in ${cityInfo.city}?`,
        answer: `There are currently ${listings.length} ${smartLower(config.name)} listed in ${cityInfo.city}, ${cityInfo.state} on ${config.brandName}.${claimed.length + featured.length > 0 ? ` Of those, ${claimed.length + featured.length} have claimed profiles with complete information and reviews.` : ''}`,
      },
      {
        question: 'What does "Sponsored" mean on a listing?',
        answer: `Sponsored providers pay for premium placement and appear at the top of search results. They have claimed profiles and typically respond faster to quote requests. All providers on ${config.brandName} — sponsored or not — are real businesses.`,
      },
    ]} />

    <RelatedContent city={cityInfo.city} state={cityInfo.state} citySlug={cityInfo.slug} />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(placeSchema)} />

  {/* ═══ CITY PAGE FILTER/SORT SCRIPT ═══ */}
  <script is:inline>
    function initCityFilters() {
      var container = document.getElementById('listing-filters');
      if (!container || container.dataset.init) return;
      container.dataset.init = 'true';

      var pills = container.querySelectorAll('.city-filter-pill');
      var sortSelect = document.getElementById('sort-select');
      var countEl = container.querySelector('.city-results-count');

      function applyFilters() {
        var activeFilter = null;
        pills.forEach(function(p) {
          if (p.classList.contains('active') && p.dataset.filter !== 'all') {
            activeFilter = p.dataset.filter;
          }
        });

        var cards = document.querySelectorAll('[data-listing-card]');
        var shown = 0;
        cards.forEach(function(card) {
          var visible = true;
          if (activeFilter === 'has-reviews' && card.dataset.hasReviews !== 'true') visible = false;
          if (activeFilter === 'rpr' && card.dataset.rpr !== 'true') visible = false;
          if (activeFilter === 'rating-4' && parseFloat(card.dataset.rating) < 4) visible = false;

          card.style.display = visible ? '' : 'none';
          if (visible) shown++;
        });
        if (countEl) countEl.textContent = shown + ' provider' + (shown !== 1 ? 's' : '');
      }

      function applySort() {
        var sortVal = sortSelect ? sortSelect.value : 'default';
        // Sort within each grid separately
        document.querySelectorAll('[data-listing-grid]').forEach(function(grid) {
          var cards = Array.from(grid.querySelectorAll('[data-listing-card]'));
          cards.sort(function(a, b) {
            if (sortVal === 'rating-desc') return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
            if (sortVal === 'reviews-desc') return parseInt(b.dataset.reviewCount) - parseInt(a.dataset.reviewCount);
            if (sortVal === 'name-asc') return a.dataset.name.localeCompare(b.dataset.name);
            return 0;
          });
          cards.forEach(function(card) { grid.appendChild(card); });
        });
      }

      pills.forEach(function(pill) {
        pill.addEventListener('click', function() {
          pills.forEach(function(p) { p.classList.remove('active'); });
          pill.classList.add('active');
          applyFilters();
        });
      });

      if (sortSelect) {
        sortSelect.addEventListener('change', function() {
          applySort();
          applyFilters();
        });
      }

      // Re-apply sort/filter after live-patch updates data attributes
      document.addEventListener('livepatch:complete', function() {
        applySort();
        applyFilters();
      });
    }

    document.addEventListener('astro:page-load', initCityFilters);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCityFilters);
    } else {
      initCityFilters();
    }
  </script>

  {/* ═══ LIVE-PATCH: Overlay D1 claimed data onto static cards ═══ */}
  <script is:inline>
    function initLivePatch() {
      var cards = document.querySelectorAll('[data-listing-card]');
      if (!cards.length) return;

      // Collect unique slugs
      var slugs = [];
      cards.forEach(function(card) {
        var slug = card.dataset.providerSlug;
        if (slug && slugs.indexOf(slug) === -1) slugs.push(slug);
      });

      // Fetch in parallel (limit to 6 concurrent)
      var queue = slugs.slice();
      var results = {};
      var fetched = 0;
      var total = slugs.length;

      function onAllFetched() {
        applyPatches();
        document.dispatchEvent(new CustomEvent('livepatch:complete'));
      }

      function fetchNext() {
        if (!queue.length) return;
        var slug = queue.shift();
        fetch('/api/listing/' + slug)
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(d) { if (d) results[slug] = d; })
          .catch(function() {})
          .then(function() {
            fetched++;
            if (fetched >= total) onAllFetched();
            else fetchNext();
          });
      }

      if (total === 0) { onAllFetched(); }
      var concurrent = Math.min(6, queue.length);
      for (var i = 0; i < concurrent; i++) fetchNext();

      function getInitials(name) {
        return name.split(/\s+/).map(function(w) { return w[0]; }).join('').substring(0, 2).toUpperCase();
      }

      function _esc(s) {
        if (!s) return '';
        var d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      var patchedCount = 0;
      var totalToFetch = 0;

      function applyPatches() {
        cards.forEach(function(card) {
          var slug = card.dataset.providerSlug;
          var result = results[slug];
          if (!result || !result.claimed) return;

          var data = result.data || {};

          // === UPGRADE UNCLAIMED → CLAIMED ===
          if (card.classList.contains('city-unclaimed-card')) {
            // Restyle the card: swap design system classes
            card.classList.remove('city-unclaimed-card', 'bg-gray-50', 'border-dashed', 'border-gray-300');
            card.classList.add('city-provider-card', 'card-hover');
            card.style.background = '';
            card.style.border = '';
            card.style.borderStyle = '';

            // Remove "Unclaimed" tag
            var unclaimedTag = card.querySelector('.city-unclaimed-tag');
            if (unclaimedTag) unclaimedTag.remove();

            // Upgrade avatar
            var avatar = card.querySelector('.city-avatar-unclaimed');
            if (avatar) {
              avatar.classList.remove('city-avatar-unclaimed', 'bg-slate-400');
              avatar.classList.add('city-avatar-claimed', 'bg-primary-600');
              if (data.name) avatar.textContent = getInitials(data.name);
            }

            // Upgrade name link
            var nameLink = card.querySelector('.city-unclaimed-name-link');
            if (nameLink) {
              nameLink.classList.remove('city-unclaimed-name-link', 'text-gray-500', 'hover:text-gray-600');
              nameLink.classList.add('city-provider-name-link', 'text-navy-950', 'hover:text-primary-600');
              if (data.name) nameLink.textContent = data.name;
            }

            // Add verified badge
            var nameDiv = card.querySelector('.text-\\[15px\\]');
            if (nameDiv && !nameDiv.querySelector('.city-verified-badge')) {
              var badge = document.createElement('span');
              badge.className = 'city-verified-badge inline-flex items-center gap-0.5 bg-emerald-50 text-emerald-600 text-[11px] font-semibold px-1.5 py-0.5 rounded-[5px] whitespace-nowrap';
              badge.innerHTML = '&#x2713;';
              nameDiv.appendChild(badge);
            }

            // Fix description
            var descEl = card.querySelector('.city-unclaimed-desc');
            if (descEl) {
              descEl.classList.remove('city-unclaimed-desc', 'text-gray-300', 'italic');
              descEl.classList.add('city-provider-desc', 'text-gray-500');
              descEl.style.fontStyle = 'normal';
            }

            // Fix tags
            card.querySelectorAll('.city-tag-faded').forEach(function(tag) {
              tag.classList.remove('city-tag-faded', 'text-gray-300');
              tag.classList.add('city-tag-muted', 'text-gray-500');
            });

            // Fix phone — un-blur and show real phone
            var phoneEl = card.querySelector('.city-phone-blurred');
            if (phoneEl && data.phone) {
              phoneEl.classList.remove('city-phone-blurred', 'text-gray-300', 'tracking-wider');
              phoneEl.classList.add('city-provider-phone', 'text-navy-950', 'font-semibold');
              phoneEl.textContent = '\u{1F4DE} ' + data.phone;
            }

            // Fix contact button
            var unavailBtn = card.querySelector('.city-btn-unavailable');
            if (unavailBtn) {
              var quoteBtn = document.createElement('button');
              quoteBtn.className = 'btn-action-secondary select-quote-btn';
              quoteBtn.dataset.selected = 'false';
              quoteBtn.dataset.providerName = data.name || card.dataset.providerName;
              quoteBtn.dataset.providerEmail = data.email || card.dataset.providerEmail;
              quoteBtn.dataset.providerSlug = slug;
              quoteBtn.innerHTML = '<svg class="w-4 h-4 hidden check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span class="btn-label">+ Quote</span>';
              unavailBtn.replaceWith(quoteBtn);
            }
          }

          // === PATCH DATA ON ALL CLAIMED CARDS ===

          // Patch name
          if (data.name) {
            var link = card.querySelector('.city-provider-name-link, .city-featured-name-link');
            if (link) link.textContent = data.name;
            card.dataset.providerName = data.name;
            card.dataset.name = data.name;
            // Update avatar initials
            var av = card.querySelector('.city-provider-avatar, .city-featured-avatar');
            if (av) av.textContent = getInitials(data.name);
          }

          // Patch description
          if (data.description) {
            var desc = card.querySelector('.city-provider-desc, .city-featured-desc');
            if (desc) {
              var text = data.description.length > 140 ? data.description.substring(0, 140) + '...' : data.description;
              desc.textContent = text;
            }
          }

          // Patch phone
          if (data.phone) {
            var ph = card.querySelector('.city-provider-phone, .city-featured-phone');
            if (ph) ph.textContent = '\u{1F4DE} ' + data.phone;
          }

          // Patch services/certifications tags
          if (data.services || data.certifications) {
            var tagWrap = card.querySelector('.city-provider-tags, .city-featured-tags');
            if (tagWrap) {
              var allTags = [].concat(data.certifications || []).concat(data.services || []).slice(0, 4);
              var isFeatured = card.classList.contains('city-featured-card');
              tagWrap.innerHTML = allTags.map(function(t) {
                return '<span class="' + (isFeatured ? 'city-tag bg-primary-50 text-primary-600 text-[11px] font-semibold px-2.5 py-1 rounded-md' : 'city-tag-muted bg-gray-100 text-gray-500 text-[11px] font-semibold px-2.5 py-1 rounded-md') + '">' + _esc(t) + '</span>';
              }).join('');
            }
          }

          // Update email for quote button
          if (data.email) {
            card.dataset.providerEmail = data.email;
            var qBtn = card.querySelector('.select-quote-btn');
            if (qBtn) qBtn.dataset.providerEmail = data.email;
          }
        });
      }
    }

    document.addEventListener('astro:page-load', initLivePatch);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLivePatch);
    } else {
      initLivePatch();
    }
  </script>
</PageLayout>

<style is:global>
  /* Hero decorative circles (pseudo-elements — can't do in Tailwind) */
