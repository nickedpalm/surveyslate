---
import PageLayout from '~/layouts/PageLayout.astro';
import MultiQuoteBar from '~/components/directory/MultiQuoteBar.astro';
import StickyCTA from '~/components/directory/StickyCTA.astro';
import LeafletMap from '~/components/directory/LeafletMap.astro';
import RelatedContent from '~/components/directory/RelatedContent.astro';
import PageHero from '~/components/directory/PageHero.astro';
import FAQAccordion from '~/components/directory/FAQAccordion.astro';
import NewsletterSignup from '~/components/directory/NewsletterSignup.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import { getListingsForCity } from '~/lib/listings';
import { titleCase, articleFor, smartLower} from '~/utils/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cityContent = await getCollection('cities');
  return citiesData.map(city => {
    const content = cityContent.find(c => c.data.slug === city.slug);
    return {
      params: { stateSlug: city.stateSlug, citySlug: city.slug },
      props: { cityInfo: city, content },
    };
  });
}

const { cityInfo, content } = Astro.props;
const allListings = getListingsForCity(cityInfo.slug);
const { Content } = content ? await render(content) : { Content: null };

// Nearby cities
function haversineDistance(lat1: number, lng1: number, lat2: number, lng2: number) {
  const R = 3959;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLng = (lng2 - lng1) * Math.PI / 180;
  const a = Math.sin(dLat/2) ** 2 + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLng/2) ** 2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
}
import { getListingCountByCity } from '~/lib/listings';
const cityCounts = getListingCountByCity();
const nearbyCities = citiesData
  .filter(c => c.slug !== cityInfo.slug && (cityCounts[c.slug] || 0) > 0)
  .map(c => ({ ...c, distance: haversineDistance(cityInfo.lat, cityInfo.lng, c.lat, c.lng), listingCount: cityCounts[c.slug] || 0 }))
  .sort((a, b) => a.distance - b.distance)
  .slice(0, 8);

// Sort: featured first, then claimed with reviews, then claimed, then unclaimed
const featured = allListings.filter(l => l.featured);
const claimed = allListings.filter(l => !l.featured && l.claimed).sort((a, b) => (b.rating || 0) - (a.rating || 0));
const unclaimed = allListings.filter(l => !l.featured && !l.claimed).sort((a, b) => (b.rating || 0) - (a.rating || 0));
const listings = [...featured, ...claimed, ...unclaimed];

const pins = listings.filter(l => l.lat && l.lat !== 0).map(l => ({ lat: l.lat, lng: l.lng, name: l.name, slug: l.slug }));

// Stats
const ratedListings = listings.filter(l => l.rating > 0);
const avgRating = ratedListings.length > 0 ? (ratedListings.reduce((s, l) => s + l.rating, 0) / ratedListings.length).toFixed(1) : null;
const totalReviews = listings.reduce((s, l) => s + (l.review_count || 0), 0);
const credentialKey = (config.primaryCredential || '').toUpperCase();
const certifiedCount = credentialKey
  ? listings.filter(l => l.certifications?.some(c => c.toUpperCase().includes(credentialKey))).length
  : 0;
const certPct = listings.length > 0 ? Math.round(certifiedCount / listings.length * 100) : 0;

const currentYear = new Date().getFullYear();
const currentMonth = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const title = listings.length > 0
  ? `${listings.length} Best ${config.name} in ${cityInfo.city}, ${cityInfo.state} (${currentYear})`
  : `Find ${config.name} in ${cityInfo.city}, ${cityInfo.state} (${currentYear})`;
const metaDescription = listings.length > 0
  ? `Compare ${listings.length} curated ${smartLower(config.name)} in ${cityInfo.city}, ${cityInfo.state}. ${certifiedCount > 0 ? `${certifiedCount} ${config.primaryCredential}-certified. ` : ''}Read real reviews, check credentials, and request free quotes. Updated ${currentMonth}.`
  : `Find ${smartLower(config.name)} in ${cityInfo.city}, ${cityInfo.state}. Browse nearby cities with verified providers, check credentials, and request free quotes. Updated ${currentMonth}.`;

// Initials helper
function getInitials(name: string): string {
  return name.split(/\s+/).map(w => w[0]).join('').substring(0, 2).toUpperCase();
}

// Star string helper
function starString(rating: number): string {
  const full = Math.floor(rating);
  const half = rating - full >= 0.5;
  return '★'.repeat(full) + (half ? '★' : '') + '☆'.repeat(5 - full - (half ? 1 : 0));
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  description: metaDescription,
  numberOfItems: listings.length,
  itemListElement: listings.map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'LocalBusiness',
      name: l.name,
      address: l.address,
      telephone: l.phone,
      url: `${config.siteUrl}/listing/${l.slug}/`,
    },
  })),
};

const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: `${config.name} in ${cityInfo.city}, ${cityInfo.state}`,
  geo: {
    '@type': 'GeoCoordinates',
    latitude: cityInfo.lat,
    longitude: cityInfo.lng,
  },
  ...(avgRating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: parseFloat(avgRating),
      reviewCount: totalReviews,
      bestRating: 5,
      worstRating: 1,
    },
  } : {}),
  containedInPlace: {
    '@type': 'AdministrativeArea',
    name: cityInfo.state,
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How much does a ${config.primaryKeyword || smartLower(config.name)} cost in ${cityInfo.city}?`,
      acceptedAnswer: { '@type': 'Answer', text: `${titleCase(config.primaryKeyword || config.name)} services in ${cityInfo.city} typically run ${config.jobValue || '$250-$1,500+'} depending on scope, complexity, and turnaround time. Expedited work and specialized equipment add cost.` },
    },
    {
      '@type': 'Question',
      name: `What should I look for in a ${config.primaryKeyword || smartLower(config.name)}?`,
      acceptedAnswer: { '@type': 'Answer', text: `Look for ${config.primaryCredential} — it's the credential that separates qualified ${smartLower(config.name)} from the rest. Also verify insurance, check reviews, and confirm they can handle your project's specific requirements.` },
    },
    {
      '@type': 'Question',
      name: `How many ${smartLower(config.name)} are in ${cityInfo.city}?`,
      acceptedAnswer: { '@type': 'Answer', text: `There are currently ${listings.length} ${smartLower(config.name)} listed in ${cityInfo.city}, ${cityInfo.state} on ${config.brandName}.${claimed.length + featured.length > 0 ? ` Of those, ${claimed.length + featured.length} have claimed profiles with complete information and reviews.` : ''}` },
    },
    {
      '@type': 'Question',
      name: `What does "Sponsored" mean on a listing?`,
      acceptedAnswer: { '@type': 'Answer', text: `Sponsored providers pay for premium placement and appear at the top of search results. They have claimed profiles and typically respond faster to quote requests. All providers on ${config.brandName} — sponsored or not — are real businesses.` },
    },
  ],
};

const ogImage = `/og/city/${cityInfo.stateSlug}/${cityInfo.slug}.png`;
const metadata = {
  title,
  description: metaDescription,
  openGraph: { images: [{ url: ogImage, width: 1200, height: 630 }] },
};
---
<PageLayout metadata={metadata} hero="dark">
  <Fragment slot="announcement"><span></span></Fragment>

  <PageHero
    title={`${config.name} in ${cityInfo.city}, ${cityInfo.state}`}
    subtitle={`Compare curated ${smartLower(config.name)}, check certifications, read reviews, and request quotes — all in one place.`}
    breadcrumbs={[
      { label: cityInfo.stateName || cityInfo.state, href: `/states/${cityInfo.stateSlug}/` },
      { label: cityInfo.city },
    ]}
    stats={[
      { value: listings.length, label: 'providers' },
      ...(avgRating ? [{ value: avgRating, label: 'avg rating' }] : []),
      ...(totalReviews > 0 ? [{ value: totalReviews, label: 'reviews' }] : []),
    ]}
    size="compact"
    bgImage={content?.data?.image}
  >
    <div class="flex gap-3 md:gap-5 mt-5 flex-wrap">
      <div class="flex items-center gap-1.5 text-xs text-white/50 font-medium"><span class="text-sm">&#x2713;</span> Researched credentials</div>
      <div class="flex items-center gap-1.5 text-xs text-white/50 font-medium"><span class="text-sm">&#x2713;</span> Free quotes, no obligation</div>
      <div class="flex items-center gap-1.5 text-xs text-white/50 font-medium"><span class="text-sm">&#x2713;</span> Updated {currentMonth}</div>
    </div>
  </PageHero>

  {/* ═══ CONTENT ═══ */}
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 md:px-10 py-5 sm:py-6 md:py-8 pb-10">

    {/* Map */}
    {pins.length > 0 && (
      <div class="mb-6 rounded-2xl overflow-hidden border border-gray-200">
        <LeafletMap pins={pins} centerLat={cityInfo.lat} centerLng={cityInfo.lng} />
      </div>
    )}

    {/* Top Providers Highlight */}
    {(() => {
      const topProviders = listings.filter(l => l.rating >= 4 && l.review_count > 0).slice(0, 3);
      return topProviders.length > 0 ? (
        <div class="mb-6 bg-gradient-to-r from-primary-50 to-primary-100 rounded-2xl border border-primary-100 p-5">
          <h2 class="text-sm font-bold text-primary-800 mb-3">Top-Rated in {cityInfo.city}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {topProviders.map((p, i) => (
              <a href={`/listing/${p.slug}/`} class="flex items-center gap-3 bg-white rounded-xl p-3 no-underline hover:shadow-md transition-shadow border border-primary-100/50">
                <div class="w-10 h-10 rounded-lg bg-primary-600 text-white flex items-center justify-center text-sm font-bold flex-shrink-0">{getInitials(p.name)}</div>
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-navy-950 truncate">{p.name}</div>
                  <div class="text-xs text-amber-600 font-medium">{starString(p.rating)} {p.rating} ({p.review_count})</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : null;
    })()}

    {/* Filters — only show when there are listings */}
    {listings.length > 0 && <div class="flex items-center gap-2 md:gap-3 mb-6 flex-wrap" id="listing-filters">
      <span class="city-results-count text-[13px] text-gray-400 font-medium">{listings.length} providers</span>
      <button class="city-filter-pill filter-pill active" data-filter="all">All</button>
      <button class="city-filter-pill filter-pill" data-filter="has-reviews">Has Reviews</button>
      <button class="city-filter-pill filter-pill" data-filter="rpr">{config.primaryCredential} Certified</button>
      <button class="city-filter-pill filter-pill" data-filter="rating-4">4+ Stars</button>
      <select class="ml-auto md:ml-auto max-md:ml-0 max-md:w-full px-3.5 py-2.5 rounded-lg text-[13px] font-medium bg-white border-[1.5px] border-gray-200 text-gray-700 cursor-pointer font-[inherit] min-h-[44px]" id="sort-select">
        <option value="default">Sort: Recommended</option>
        <option value="rating-desc">Rating (high to low)</option>
        <option value="reviews-desc">Most Reviews</option>
        <option value="name-asc">Name (A-Z)</option>
      </select>
    </div>}

    {listings.length > 0 ? (
      <div data-pagefind-body>

        {/* ═══ FEATURED PROVIDERS ═══ */}
        {featured.length > 0 && (
          <>
            <div class="section-label">
              <span>&#x26A1; SPONSORED PROVIDERS</span>
              <span class="section-label-line"></span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-9">
              {featured.map(listing => {
                const initials = getInitials(listing.name);
                const hasRPR = credentialKey && listing.certifications?.some(c => c.toUpperCase().includes(credentialKey));
                const stars = starString(listing.rating);
                const desc = listing.description && listing.description.length > 180 ? listing.description.slice(0, 180) + '...' : listing.description;
                const tags = [...(listing.certifications || []), ...(listing.services || [])].slice(0, 4);
                return (
                  <div class="card-featured city-featured-card overflow-hidden relative" data-listing-card data-has-reviews={listing.review_count > 0 ? 'true' : 'false'} data-rpr={hasRPR ? 'true' : 'false'} data-rating={String(listing.rating || 0)} data-review-count={String(listing.review_count || 0)} data-name={listing.name} data-provider-name={listing.name} data-provider-email={listing.email || ''} data-provider-slug={listing.slug}>
                    <div class="bg-gradient-to-br from-primary-600 to-primary-700 text-white text-[11px] font-bold tracking-wide px-4 py-1.5 flex items-center gap-1.5" title="This provider pays for premium placement">&#x26A1; SPONSORED {listing.review_count > 0 ? `\u00B7 ${listing.rating} stars from ${listing.review_count} reviews` : ''}</div>
                    <div class="p-5">
                      <div class="flex items-start gap-4">
                        <div class="city-featured-avatar w-14 h-14 rounded-[14px] flex items-center justify-center text-xl font-bold text-white flex-shrink-0 bg-gradient-to-br from-primary-600 to-primary-800">{initials}</div>
                        <div class="flex-1">
                          <div class="text-[17px] font-bold mb-0.5 flex items-center gap-2 flex-wrap">
                            <a href={`/listing/${listing.slug}/`} class="city-featured-name-link text-navy-950 no-underline hover:text-primary-600">{listing.name}</a>
                            {hasRPR && <span class="city-verified-badge inline-flex items-center gap-0.5 bg-emerald-50 text-emerald-600 text-[11px] font-semibold px-1.5 py-0.5 rounded-[5px] whitespace-nowrap">&#x2713; {config.primaryCredential}</span>}
                          </div>
                          <div class="text-[13px] text-gray-500">{listing.city}, {listing.state}{listing.coverage_area ? ` \u00B7 ${listing.coverage_area}` : ''}</div>
                          {listing.review_count > 0 && (
                            <div class="flex items-center gap-1.5 mt-1.5">
                              <span class="text-amber-500 text-sm">{stars}</span>
                              <span class="text-sm font-bold">{listing.rating}</span>
                              <span class="text-[13px] text-gray-400">({listing.review_count} reviews)</span>
                            </div>
                          )}
                        </div>
                      </div>
                      {desc && <div class="city-featured-desc text-[13px] text-gray-600 leading-relaxed mt-3 line-clamp-2">{desc}</div>}
                      {tags.length > 0 && (
                        <div class="city-featured-tags flex flex-wrap gap-1.5 mt-3">
                          {tags.map(t => <span class="city-tag bg-primary-50 text-primary-600 text-[11px] font-semibold px-2.5 py-1 rounded-md">{t}</span>)}
                        </div>
                      )}
                      <div class="flex items-center justify-between mt-4 pt-3.5 border-t border-gray-100 flex-wrap gap-2">
                        <div>
                          {listing.phone && <div class="city-featured-phone flex items-center gap-1.5 text-[13px] font-semibold text-navy-950">&#x1F4DE; {listing.phone}</div>}
                        </div>
                        {listing.email ? (
                          <button class="btn-action-primary select-quote-btn" data-selected="false" data-provider-name={listing.name} data-provider-email={listing.email} data-provider-slug={listing.slug}>
                            <svg class="w-4 h-4 hidden check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span class="btn-label">+ Request Quote</span>
                          </button>
                        ) : listing.website ? (
                          <a href={listing.website} target="_blank" rel="noopener" class="btn-action-secondary">Visit Website</a>
                        ) : listing.phone ? (
                          <a href={`tel:${listing.phone}`} class="btn-action-secondary">Call</a>
                        ) : null}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </>
        )}

        {/* ═══ CLAIMED PROVIDERS ═══ */}
        {claimed.length > 0 && (
          <>
            <div class="section-label">
              <span>CLAIMED PROVIDERS</span>
              <span class="section-label-line"></span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3.5 mb-9" data-listing-grid>
              {claimed.map(listing => {
                const initials = getInitials(listing.name);
                const hasRPR = listing.certifications?.some(c => c.toUpperCase().includes(config.primaryCredential.toUpperCase()));
                const stars = starString(listing.rating);
                const desc = listing.description && listing.description.length > 140 ? listing.description.slice(0, 140) + '...' : listing.description;
                const tags = [...(listing.certifications || []), ...(listing.services || [])].slice(0, 3);
                return (
                  <div class="card-hover city-provider-card p-5" data-listing-card data-has-reviews={listing.review_count > 0 ? 'true' : 'false'} data-rpr={hasRPR ? 'true' : 'false'} data-rating={String(listing.rating || 0)} data-review-count={String(listing.review_count || 0)} data-name={listing.name} data-provider-name={listing.name} data-provider-email={listing.email || ''} data-provider-slug={listing.slug}>
                    <div class="flex items-start gap-3.5">
                      <div class="city-provider-avatar city-avatar-claimed w-[46px] h-[46px] rounded-xl flex items-center justify-center text-base font-bold text-white flex-shrink-0 bg-primary-600">{initials}</div>
                      <div class="flex-1 min-w-0">
                        <div class="text-[15px] font-bold mb-0.5 flex items-center gap-1.5 flex-wrap">
                          <a href={`/listing/${listing.slug}/`} class="city-provider-name-link text-navy-950 no-underline hover:text-primary-600">{listing.name}</a>
                          {hasRPR && <span class="city-verified-badge inline-flex items-center gap-0.5 bg-emerald-50 text-emerald-600 text-[11px] font-semibold px-1.5 py-0.5 rounded-[5px] whitespace-nowrap">&#x2713;</span>}
                        </div>
                        <div class="text-xs text-gray-500">{listing.city}, {listing.state}</div>
                        {listing.review_count > 0 && (
                          <div class="flex items-center gap-1.5 mt-1 text-[13px]">
                            <span class="text-amber-500 text-sm">{stars}</span>
                            <span class="text-sm font-bold">{listing.rating}</span>
                            <span class="text-[13px] text-gray-400">({listing.review_count} reviews)</span>
                          </div>
                        )}
                      </div>
                    </div>
                    {desc && <div class="city-provider-desc text-[13px] text-gray-500 leading-snug mt-2.5 line-clamp-2">{desc}</div>}
                    {tags.length > 0 && (
                      <div class="city-provider-tags flex flex-wrap gap-1.5 mt-2.5">
                        {tags.map(t => <span class="city-tag-muted bg-gray-100 text-gray-500 text-[11px] font-semibold px-2.5 py-1 rounded-md">{t}</span>)}
                      </div>
                    )}
                    <div class="flex items-center justify-between mt-3.5 pt-3 border-t border-gray-100 flex-wrap gap-2">
                      {listing.phone ? <span class="city-provider-phone text-[13px] font-semibold text-navy-950">&#x1F4DE; {listing.phone}</span> : <span></span>}
                      {listing.email ? (
                        <button class="btn-action-secondary select-quote-btn" data-selected="false" data-provider-name={listing.name} data-provider-email={listing.email} data-provider-slug={listing.slug}>
                          <svg class="w-4 h-4 hidden check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                          <span class="btn-label">+ Quote</span>
                        </button>
                      ) : listing.website ? (
                        <a href={listing.website} target="_blank" rel="noopener" class="btn-action-secondary">Visit Website</a>
                      ) : null}
                    </div>
                  </div>
                );
              })}
            </div>
          </>
        )}

        {/* Mid-page CTA */}
        <div class="bg-gradient-to-br from-primary-50 to-primary-100 border border-primary-200 rounded-2xl px-8 py-7 mb-9 flex items-center justify-between flex-wrap gap-4 max-md:flex-col max-md:text-center">
          <div>
            <h3 class="text-[17px] font-bold text-primary-800 mb-1">Are you a {config.primaryKeyword || smartLower(config.name)} in {cityInfo.city}?</h3>
            <p class="text-sm text-primary-500">Claim your free listing or get Sponsored placement to appear above other providers.</p>
          </div>
          <a href="/advertise/" class="btn-action-primary">List Your Business &rarr;</a>
        </div>

        {/* ═══ OTHER PROVIDERS (Unclaimed) ═══ */}
        {unclaimed.length > 0 && (
          <>
            <div class="section-label">
              <span>OTHER PROVIDERS</span>
              <span class="section-label-line"></span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3.5 mb-9" data-listing-grid>
              {unclaimed.map(listing => {
                const initials = getInitials(listing.name);
                const hasRPR = listing.certifications?.some(c => c.toUpperCase().includes(config.primaryCredential.toUpperCase()));
                const stars = starString(listing.rating);
                const desc = listing.description && listing.description.length > 140 ? listing.description.slice(0, 140) + '...' : listing.description;
                const tags = [...(listing.certifications || []), ...(listing.services || [])].slice(0, 2);
                return (
                  <div class="bg-gray-50 rounded-card p-5 border border-dashed border-gray-300 city-unclaimed-card relative" data-listing-card data-has-reviews={listing.review_count > 0 ? 'true' : 'false'} data-rpr={hasRPR ? 'true' : 'false'} data-rating={String(listing.rating || 0)} data-review-count={String(listing.review_count || 0)} data-name={listing.name} data-provider-name={listing.name} data-provider-email={listing.email || ''} data-provider-slug={listing.slug}>
                    <span class="city-unclaimed-tag absolute top-3 right-3 text-[10px] font-semibold text-gray-400 bg-gray-100 px-2 py-0.5 rounded">Unclaimed</span>
                    <div class="flex items-start gap-3.5">
                      <div class="city-provider-avatar city-avatar-unclaimed w-[46px] h-[46px] rounded-xl flex items-center justify-center text-base font-bold text-white flex-shrink-0 bg-slate-400">{initials}</div>
                      <div class="flex-1 min-w-0">
                        <div class="text-[15px] font-bold mb-0.5 flex items-center gap-1.5 flex-wrap">
                          <a href={`/listing/${listing.slug}/`} class="city-unclaimed-name-link text-gray-500 no-underline hover:text-gray-600">{listing.name}</a>
                        </div>
                        <div class="text-xs text-gray-500">{listing.city}, {listing.state}</div>
                        {listing.review_count > 0 ? (
                          <div class="flex items-center gap-1.5 mt-1 text-[13px]">
                            <span class="text-amber-500 text-sm">{stars}</span>
                            <span class="text-sm font-bold">{listing.rating}</span>
                            <span class="text-[13px] text-gray-400">({listing.review_count} reviews)</span>
                          </div>
                        ) : (
                          <div class="text-xs text-gray-500 italic mt-1">No reviews yet</div>
                        )}
                      </div>
                    </div>
                    {listing.review_count > 0 && desc ? (
                      <div class="city-provider-desc text-[13px] text-gray-500 leading-snug mt-2.5 line-clamp-2">{desc}</div>
                    ) : (
                      <div class="city-unclaimed-desc text-[13px] text-gray-500 italic leading-snug mt-2.5">No description available. This listing has not been claimed by the business owner.</div>
                    )}
                    {tags.length > 0 && (
                      <div class="city-provider-tags flex flex-wrap gap-1.5 mt-2.5">
                        {tags.map(t => <span class="city-tag-faded bg-gray-100 text-gray-500 text-[11px] font-semibold px-2.5 py-1 rounded-md">{t}</span>)}
                      </div>
                    )}
                    <div class="flex items-center justify-between mt-3.5 pt-3 border-t border-gray-100 flex-wrap gap-2">
