    {/* How It Works */}
    <div class="bg-white rounded-2xl border border-gray-200 px-4 sm:px-6 md:px-8 py-6 md:py-7 mb-9 mt-5">
      <h2 class="text-lg font-bold mb-5">How {config.brandName} Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
