    {/* Fallback: if no Content, render nearby/newsletter inline */}
    {!Content && nearbyCities.length > 0 && (
      <div class="mb-9">
        <h2 class="text-lg font-bold mb-4">Nearby Cities</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3">
          {nearbyCities.map(c => (
            <a class="card-hover p-4 no-underline text-inherit" href={`/locations/${c.stateSlug}/${c.slug}/`}>
              <div class="text-sm font-bold text-navy-950">{c.city}</div>
              <div class="text-xs text-gray-400">{c.state}</div>
              <div class="text-xs text-gray-500 mt-1">{c.listingCount} provider{c.listingCount !== 1 ? 's' : ''}</div>
            </a>
          ))}
