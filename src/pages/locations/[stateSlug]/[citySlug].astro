                </div>
              )}
              {certifiedCount > 0 && (
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-500">{config.primaryCredential} Certified</span>
                  <span class="font-bold text-navy-950">{certifiedCount} ({certPct}%)</span>
                </div>
