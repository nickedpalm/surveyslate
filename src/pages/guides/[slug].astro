---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import Turnstile from '~/components/common/Turnstile.astro';
import config from '~/config';
import guides from '~/data/guides.json';
import citiesData from '~/data/cities.json';

export function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;

const categoryColors: Record<string, { bg: string; text: string }> = {
  Pricing: { bg: 'bg-emerald-50', text: 'text-emerald-700' },
  'How-To': { bg: 'bg-blue-50', text: 'text-blue-700' },
  Hiring: { bg: 'bg-rose-50', text: 'text-rose-700' },
};
const colors = categoryColors[guide.category] || { bg: 'bg-gray-50', text: 'text-gray-700' };

// City options for dropdown
const cityOptions = citiesData
  .sort((a, b) => a.city.localeCompare(b.city))
  .map(c => ({ value: `${c.city}, ${c.state}`, label: `${c.city}, ${c.state}` }));

// Other guides for cross-promotion
const otherGuides = guides.filter(g => g.slug !== guide.slug);

const faqItems = [
  {
    q: 'Is this guide really free?',
    a: 'Yes, completely free. We ask for your email so we can send you the download link and notify you when we publish updated versions.',
  },
  {
    q: 'How current is the data?',
    a: `This guide is updated for ${new Date().getFullYear()} using real pricing and provider data from our directory of verified ${config.primaryKeyword}s across all 50 states.`,
  },
  {
    q: 'Will I receive spam?',
    a: `No. You will receive the guide download link and occasional updates about the ${config.industry} industry (no more than once per month). You can unsubscribe at any time.`,
  },
];

const metadata = {
  title: `${guide.title} | Free Download | ${config.brandName}`,
  description: guide.description,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: guide.title,
  description: guide.description,
  url: `${config.siteUrl}/guides/${guide.slug}/`,
  publisher: {
    '@type': 'Organization',
    name: config.brandName,
    url: config.siteUrl,
  },
};
---
<PageLayout metadata={metadata} hero="dark">
  <Fragment slot="announcement"><span></span></Fragment>
  <Turnstile />

  <!-- Hero Section -->
  <div class="hero-gradient text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">
      <Breadcrumbs crumbs={[
        { label: 'Free Guides', href: '/guides/' },
        { label: guide.title },
      ]} dark />
      <div class="mt-6 grid lg:grid-cols-2 gap-10 items-center">
        <!-- Left: Guide info -->
        <div>
          <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${colors.bg} ${colors.text} mb-4`}>
            {guide.category}
          </span>
          <h1 class="text-3xl sm:text-4xl lg:text-[44px] font-extrabold leading-tight tracking-tight">
            {guide.title}
          </h1>
          <p class="mt-4 text-lg text-primary-100/80 leading-relaxed">
            {guide.subtitle}
          </p>
          <ul class="mt-6 space-y-3">
            {guide.bullets.map((bullet) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-primary-500/30 flex items-center justify-center text-xs text-primary-200">&#10003;</span>
                <span class="text-primary-100">{bullet}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 flex items-center gap-4 text-sm text-primary-200/70">
            <span>Free for {config.buyerPersona}</span>
            <span class="w-1 h-1 rounded-full bg-primary-400/50"></span>
            <span>Updated {new Date().getFullYear()}</span>
          </div>
        </div>

        <!-- Right: Email capture form -->
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-xl" id="guide-form-card">
          <h2 class="text-xl font-bold text-gray-900 mb-1">Get Your Free Copy</h2>
          <p class="text-sm text-gray-500 mb-5">Enter your details below and we'll send you the guide instantly.</p>
          <form id="guide-form" class="space-y-4">
            <div>
              <label for="guide-name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input
                type="text"
                id="guide-name"
                name="name"
                required
                autocomplete="name"
                placeholder="Jane Smith"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none"
              />
            </div>
            <div>
              <label for="guide-email" class="block text-sm font-medium text-gray-700 mb-1">Work Email</label>
              <input
                type="email"
                id="guide-email"
                name="email"
                required
                autocomplete="email"
                placeholder="jane@lawfirm.com"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none"
              />
            </div>
            <div>
              <label for="guide-city" class="block text-sm font-medium text-gray-700 mb-1">City (optional)</label>
              <select
                id="guide-city"
                name="city"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none bg-white"
              >
                <option value="">Select your city...</option>
                {cityOptions.map(c => (
                  <option value={c.value}>{c.label}</option>
                ))}
              </select>
            </div>
            <div class="cf-turnstile" data-sitekey={config.turnsiteSitekey} data-size="compact"></div>
            <button
              type="submit"
              class="w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Download Free Guide
            </button>
            <p id="guide-form-msg" class="text-xs text-gray-500 text-center">
              Free. No spam. Unsubscribe anytime.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">

    <!-- Preview Section -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">What's Inside</h2>
      <div class="max-w-3xl mx-auto">
        <div class="relative bg-gray-50 rounded-2xl border border-gray-200 p-8 sm:p-10 overflow-hidden">
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p class="font-semibold text-gray-900">{guide.description}</p>
            <p>This guide covers everything you need to know, with real data sourced from our directory of verified {config.primaryKeyword}s across the United States.</p>
            <ul class="space-y-2">
              {guide.bullets.map((bullet) => (
                <li class="flex items-start gap-2">
                  <span class="text-primary-600 mt-0.5">&#8226;</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
          <!-- Blur overlay -->
          <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-gray-50 via-gray-50/95 to-transparent flex items-end justify-center pb-4">
            <a href="#guide-form-card" class="px-6 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors no-underline">
              Download to Read Full Guide &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="mb-16 max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqItems.map((item) => (
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="font-semibold text-gray-900 mb-2">{item.q}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Other Guides -->
    {otherGuides.length > 0 && (
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">More Free Guides</h2>
        <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
          {otherGuides.map((g) => {
            const gColors = categoryColors[g.category] || { bg: 'bg-gray-50', text: 'text-gray-700' };
            return (
              <a href={`/guides/${g.slug}/`}
                 class="block bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all no-underline group p-5">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${gColors.bg} ${gColors.text} mb-2`}>
                  {g.category}
                </span>
                <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary-600 transition-colors leading-snug mb-1">
                  {g.title}
                </h3>
                <p class="text-sm text-gray-500">{g.subtitle}</p>
                <span class="inline-flex items-center mt-3 text-sm text-primary-600 font-medium group-hover:underline">
                  Download Free Guide &rarr;
                </span>
              </a>
            );
          })}
        </div>
      </div>
    )}
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</PageLayout>

<script define:vars={{ pdfUrl: guide.pdfUrl, guideTitle: guide.title, contactEmail: config.contactEmail }}>
  window.__guidePdfUrl = pdfUrl;
  window.__guideTitle = guideTitle;
  window.__contactEmail = contactEmail;
</script>

<script>
  function initGuideForm() {
    const form = document.getElementById('guide-form') as HTMLFormElement | null;
    const msg = document.getElementById('guide-form-msg');
    if (!form || form.dataset.init) return;
    form.dataset.init = 'true';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nameInput = form.querySelector('input[name="name"]') as HTMLInputElement;
      const emailInput = form.querySelector('input[name="email"]') as HTMLInputElement;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      const name = nameInput?.value?.trim();
      const email = emailInput?.value?.trim();
      if (!email || !name) return;
      if (btn.disabled) return;

      btn.disabled = true;
      btn.textContent = 'Submitting...';

      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 10000);

      try {
        const pdfUrl = (window as any).__guidePdfUrl;
        const guideTitle = (window as any).__guideTitle;

        const resp = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            name,
            list_id: 6,
            guide_title: guideTitle || '',
            guide_pdf_url: pdfUrl || '',
          }),
          signal: controller.signal,
        });
        clearTimeout(timeout);

        if (resp.ok) {
          // Replace form with success message
          const card = document.getElementById('guide-form-card');
          if (card) {
            card.innerHTML = `
              <div class="text-center py-4">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
                  <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <h2 class="text-xl font-bold text-gray-900 mb-2">Check Your Email</h2>
                <p class="text-gray-600 mb-1">We just sent your free guide to:</p>
                <p class="font-semibold text-gray-900 mb-4">${email.replace(/</g, '&lt;')}</p>
                <p class="text-sm text-gray-500">Didn't get it? Check your spam folder, or <a href="mailto:${(window as any).__contactEmail || 'contact@example.com'}" class="text-primary-600 underline">contact us</a>.</p>
              </div>
            `;
          }
        } else {
          throw new Error('Failed');
        }
      } catch {
        clearTimeout(timeout);
        if (msg) {
          msg.textContent = 'Something went wrong. Please try again.';
          msg.classList.remove('text-gray-500');
          msg.classList.add('text-red-600');
        }
        btn.disabled = false;
        btn.textContent = 'Download Free Guide';
      }
    });
  }

  document.addEventListener('astro:page-load', initGuideForm);
</script>
