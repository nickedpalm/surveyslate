---
import PageLayout from '~/layouts/PageLayout.astro';
import PageHero from '~/components/directory/PageHero.astro';
import config from '~/config';
import guides from '~/data/guides.json';
import { titleCase, articleFor, smartLower } from '~/utils/utils';

const categoryColors: Record<string, { bg: string; text: string }> = {
  Pricing: { bg: 'bg-emerald-50', text: 'text-emerald-700' },
  'How-To': { bg: 'bg-primary-50', text: 'text-primary-700' },
  Hiring: { bg: 'bg-rose-50', text: 'text-rose-700' },
};

const buyerTitle = titleCase(config.buyerPersona || 'Buyers');
const metadata = {
  title: `Free Guides for ${buyerTitle}`,  // titleTemplate appends " | <brand>"
  description: `Download free guides on ${config.primaryKeyword} pricing, hiring tips, and industry best practices. Built for ${config.buyerPersona || 'professionals'}.`,
};
---
<PageLayout metadata={metadata} hero="dark">
  <Fragment slot="announcement"><span></span></Fragment>

  <PageHero
    title={`Free Guides for ${buyerTitle}`}
    subtitle={`Practical, data-driven guides on hiring ${smartLower(config.primaryKeyword || config.name)}s, managing costs, and ensuring quality. Download instantly — no strings attached.`}
    breadcrumbs={[{ label: 'Free Guides' }]}
    meta={[`${guides.length} guides`, `Updated ${new Date().getFullYear()}`]}
  />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Guide Cards -->
    <div class="relative -mt-8 mb-16">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {guides.map((guide) => {
          const colors = categoryColors[guide.category] || { bg: 'bg-gray-50', text: 'text-gray-700' };
          return (
            <a href={`/guides/${guide.slug}/`}
               class="block bg-white rounded-2xl border border-gray-200 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all no-underline group overflow-hidden">
              <div class="p-6">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${colors.bg} ${colors.text} mb-3`}>
                  {guide.category}
                </span>
                <h2 class="text-xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors leading-snug mb-2">
                  {guide.title}
                </h2>
                <p class="text-sm text-gray-500 leading-relaxed mb-4">
                  {guide.subtitle}
                </p>
                <span class="inline-flex items-center text-sm text-primary-600 font-semibold group-hover:gap-2 transition-all">
                  Download Free Guide <span class="ml-1 transition-transform group-hover:translate-x-1">&rarr;</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- Trust Section -->
    <div class="mb-16 text-center">
      <p class="text-sm text-gray-500 mb-4">Trusted by {smartLower(config.buyerPersona || 'buyers')} nationwide</p>
      <div class="flex justify-center gap-8 flex-wrap text-gray-400 text-sm">
        <div class="flex items-center gap-2">
          <span class="text-2xl">&#128220;</span>
          <span>{guides.length} free guides</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">&#9989;</span>
          <span>Real provider data</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">&#128197;</span>
          <span>Updated for {new Date().getFullYear()}</span>
        </div>
      </div>
    </div>

    <!-- Provider CTA -->
    <div class="mb-16">
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-8 sm:p-10 text-center">
        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3">Are You {articleFor(config.primaryKeyword || config.name, true)} {titleCase(config.primaryKeyword || config.name)}?</h2>
        <p class="text-gray-600 mb-6 max-w-lg mx-auto">
          Claim your free listing on {config.brandName} and start receiving quote requests from {smartLower(config.buyerPersona || 'buyers')} in your area.
        </p>
        <a href="/provider/login/"
           class="inline-flex items-center px-6 py-3 bg-primary-800 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors">
          Claim Your Listing &rarr;
        </a>
      </div>
    </div>

  </div>
</PageLayout>
