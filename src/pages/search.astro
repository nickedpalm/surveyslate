---
import PageLayout from '~/layouts/PageLayout.astro';
import { smartLower, articleFor } from '~/utils/utils';
import PageHero from '~/components/directory/PageHero.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import { getListingCountByCity, getAllListings } from '~/lib/listings';
import { getCollection } from 'astro:content';

const cityCounts = getListingCountByCity();
const allListings = getAllListings();
const totalProviders = allListings.length;
const totalCities = Object.keys(cityCounts).length;

const metadata = {
  title: `Find ${articleFor(config.primaryKeyword || config.name)} ${config.primaryKeyword || config.name}`,
  description: `Search ${config.name} — ${totalProviders.toLocaleString()}+ curated ${smartLower(config.name)} across ${totalCities} cities. Filter by city, credentials, and services.`,
};

const topCities = citiesData
  .map(c => ({ ...c, count: cityCounts[c.slug] || 0 }))
  .filter(c => c.count > 0)
  .sort((a, b) => b.count - a.count);
const topCitiesDisplay = topCities.slice(0, 9);

const posts = await getCollection('blog');
const recentPosts = posts
  .filter(p => p.data.pubDate)
  .sort((a, b) => (b.data.pubDate?.getTime() || 0) - (a.data.pubDate?.getTime() || 0))
  .slice(0, 3);
---
<PageLayout metadata={metadata} hero="dark">
  <Fragment slot="announcement"><span></span></Fragment>

  <PageHero
    title={`Find ${articleFor(config.primaryKeyword || config.name)} ${config.primaryKeyword || config.name}`}
    subtitle={`Search ${totalProviders.toLocaleString()}+ curated providers across ${totalCities} cities. Every listing includes credentials, services, and direct contact.`}
  >
    <div class="max-w-xl mt-6">
      <div id="search" class="min-h-[56px]"></div>
    </div>
    <p class="text-white/60 text-sm mt-3">
      Search by provider name, city, service, or keyword — or <a href="/states/all/" class="text-white underline hover:no-underline">browse by state</a>
    </p>
  </PageHero>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Zip code redirect banner -->
    <div id="zip-banner" class="hidden mb-6">
      <div class="bg-primary-50 border border-primary-200 rounded-xl p-5">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-lg bg-primary-100 flex-shrink-0 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div class="flex-1">
            <p class="font-semibold text-slate-900" id="zip-banner-title">Providers near you</p>
            <p class="text-sm text-slate-600 mt-0.5" id="zip-banner-subtitle"></p>
            <div id="zip-banner-cities" class="flex flex-wrap gap-2 mt-3"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Search results appear here via Pagefind -->
    <div id="search-results-area"></div>

    <!-- Empty state: shown when no search query -->
    <div id="search-empty-state">

      <!-- How it works -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12 mt-4">
        <div class="text-center px-4">
          <div class="w-12 h-12 bg-primary-50 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <h3 class="font-semibold text-default mb-1">Search or Browse</h3>
          <p class="text-sm text-muted">Type a city, zip code, or provider name above — or browse by state to see all providers near you.</p>
        </div>
        <div class="text-center px-4">
          <div class="w-12 h-12 bg-primary-50 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="font-semibold text-default mb-1">Compare Providers</h3>
          <p class="text-sm text-muted">Review credentials, certifications, services offered, and real client reviews side by side.</p>
        </div>
        <div class="text-center px-4">
          <div class="w-12 h-12 bg-primary-50 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-semibold text-default mb-1">Request a Quote</h3>
          <p class="text-sm text-muted">Submit a quote request directly from any listing page — the provider gets your details instantly.</p>
        </div>
      </div>

      <!-- Top cities -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-default mb-1">Top Markets</h2>
        <p class="text-sm text-muted mb-4">Cities with the most {smartLower(config.name)} on our platform.</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {topCitiesDisplay.map(c => (
            <a href={`/locations/${c.stateSlug}/${c.slug}/`} class="flex items-center justify-between bg-white rounded-xl border border-gray-200 px-4 py-3 no-underline hover:border-primary hover:shadow-sm transition-all group">
              <div>
                <p class="font-semibold text-default group-hover:text-primary-600">{c.city}</p>
                <p class="text-sm text-muted">{c.state}</p>
              </div>
              <span class="text-sm font-medium text-primary-600 bg-primary-50 px-2.5 py-1 rounded-full">{c.count}</span>
            </a>
          ))}
        </div>
        <div class="text-center mt-4">
          <a href="/states/all/" class="text-sm text-primary font-medium hover:underline">View all {totalCities} cities &rarr;</a>
        </div>
      </div>

      <!-- Recent posts -->
      {recentPosts.length > 0 && (
        <div>
          <h2 class="text-xl font-bold text-default mb-1">Industry Insights</h2>
          <p class="text-sm text-muted mb-4">Guides and analysis for {config.buyerPersona} hiring {smartLower(config.name)}.</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {recentPosts.map(post => (
              <a href={`/blog/${post.id}/`} class="block bg-white rounded-xl border border-gray-200 p-5 no-underline hover:border-primary hover:shadow-sm transition-all">
                <p class="font-semibold text-default text-sm leading-snug">{post.data.title}</p>
                {post.data.description && (
                  <p class="text-xs text-muted mt-2 line-clamp-2">{post.data.description}</p>
                )}
                {post.data.pubDate && (
                  <p class="text-xs text-gray-400 mt-3">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
                )}
              </a>
            ))}
          </div>
          <div class="text-center mt-4">
            <a href="/blog/" class="text-sm text-primary font-medium hover:underline">Read more on our blog &rarr;</a>
          </div>
        </div>
      )}
    </div>
  </div>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <style>
    /* Move Pagefind results below hero into the results area */
    #search .pagefind-ui__search-input {
      font-size: 1.1rem;
      padding: 0.875rem 1rem;
      border-radius: 0.5rem;
    }
    #search .pagefind-ui__search-clear {
      top: calc(50% - 10px);
    }
  </style>
  <!-- City data for zip lookup -->
  <script type="application/json" id="search-city-data" set:html={JSON.stringify(
    topCities.map(c => ({
      slug: c.slug,
      stateSlug: c.stateSlug,
      city: c.city,
      state: c.state,
      lat: c.lat,
      lng: c.lng,
      count: c.count,
    }))
  )} />

  <script is:inline define:vars={{ dirName: config.name }}>
    function initZipDetect() {
      const banner = document.getElementById('zip-banner');
      const bannerTitle = document.getElementById('zip-banner-title');
      const bannerSubtitle = document.getElementById('zip-banner-subtitle');
      const bannerCities = document.getElementById('zip-banner-cities');
      if (!banner) return;

      const cities = JSON.parse(document.getElementById('search-city-data')?.textContent || '[]');

      function haversine(lat1, lng1, lat2, lng2) {
        const R = 3959;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLng = (lng2 - lng1) * Math.PI / 180;
        const a = Math.sin(dLat/2) ** 2 + Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) * Math.sin(dLng/2) ** 2;
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      }

      function findNearest(lat, lng, n) {
        return cities
          .map(c => ({ ...c, dist: haversine(lat, lng, c.lat, c.lng) }))
          .sort((a, b) => a.dist - b.dist)
          .slice(0, n);
      }

      function showBanner(zip, nearest) {
        bannerTitle.textContent = `${dirName} near ${zip}`;
        bannerSubtitle.textContent = nearest.length > 0
          ? `We found providers in ${nearest.length} nearby ${nearest.length === 1 ? 'city' : 'cities'}. Click to browse.`
          : 'No nearby cities found in our directory.';
        bannerCities.innerHTML = nearest.map(c =>
          `<a href="/locations/${c.stateSlug}/${c.slug}/" class="inline-flex items-center gap-2 bg-white border border-primary-200 hover:border-primary-400 rounded-lg px-4 py-2.5 no-underline transition-colors group">
            <div>
              <span class="font-semibold text-slate-900 group-hover:text-primary-600 text-sm">${c.city}, ${c.state}</span>
              <span class="text-xs text-slate-500 ml-1">${Math.round(c.dist)} mi</span>
            </div>
            <span class="text-sm font-bold text-primary-600">${c.count} providers</span>
          </a>`
        ).join('');
        banner.classList.remove('hidden');
      }

      function hideBanner() { banner.classList.add('hidden'); }

      let lastZip = '';
      function checkForZip(value) {
        const trimmed = value.trim();
        const isZip = /^\d{5}$/.test(trimmed);
        if (!isZip) { hideBanner(); lastZip = ''; return; }
        if (trimmed === lastZip) return;
        lastZip = trimmed;

        // Geocode via free API
        fetch(`https://api.zippopotam.us/us/${trimmed}`)
          .then(r => { if (!r.ok) throw new Error('Not found'); return r.json(); })
          .then(data => {
            const place = data.places?.[0];
            if (!place) { hideBanner(); return; }
            const lat = parseFloat(place.latitude);
            const lng = parseFloat(place.longitude);
            const nearest = findNearest(lat, lng, 4);
            showBanner(trimmed, nearest);
          })
          .catch(() => {
            // Fallback: hide banner, let Pagefind show results
            hideBanner();
          });
      }

      // Watch for input changes
      const observer = new MutationObserver(() => {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input && !input.dataset.zipWatch) {
          input.dataset.zipWatch = 'true';
          input.addEventListener('input', () => checkForZip(input.value));
          // Check initial value
          if (input.value) checkForZip(input.value);
        }
      });
      observer.observe(document.getElementById('search'), { childList: true, subtree: true });

      // Also check URL param
      const q = new URLSearchParams(window.location.search).get('q');
      if (q && /^\d{5}$/.test(q.trim())) {
        // Pre-fetch before Pagefind loads
        const trimmed = q.trim();
        fetch(`https://api.zippopotam.us/us/${trimmed}`)
          .then(r => { if (!r.ok) throw new Error('Not found'); return r.json(); })
          .then(data => {
            const place = data.places?.[0];
            if (!place) return;
            const nearest = findNearest(parseFloat(place.latitude), parseFloat(place.longitude), 4);
            showBanner(trimmed, nearest);
            lastZip = trimmed;
          })
          .catch(() => {});
      }
    }

    document.addEventListener('astro:page-load', initZipDetect);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initZipDetect);
    } else {
      initZipDetect();
    }
  </script>

  <script is:inline>
    function initPagefind() {
      const el = document.getElementById('search');
      if (!el || el.dataset.pagefindInit) return;
      el.dataset.pagefindInit = 'true';

      const emptyState = document.getElementById('search-empty-state');
      const resultsArea = document.getElementById('search-results-area');

      function setup() {
        if (typeof PagefindUI === 'undefined') return false;
        el.innerHTML = '';
        new PagefindUI({
          element: '#search',
          // Explicit bundlePath — without it Pagefind tries to load
          // /search/pagefind-entry.json (relative) which 404s.
          bundlePath: '/pagefind/',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
        });
        const params = new URLSearchParams(window.location.search);
        const q = params.get('q');
        if (q) {
          const input = document.querySelector('.pagefind-ui__search-input');
          if (input) {
            input.value = q;
            input.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }

        // Toggle empty state based on search input
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input && emptyState) {
          function toggleEmpty() {
            if (input.value.trim().length > 0) {
              emptyState.classList.add('hidden');
            } else {
              emptyState.classList.remove('hidden');
            }
          }
          input.addEventListener('input', toggleEmpty);
          toggleEmpty();
        }

        return true;
      }

      if (!setup()) {
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = setup;
        document.head.appendChild(script);
      }
    }

    document.addEventListener('astro:page-load', initPagefind);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPagefind);
    } else {
      initPagefind();
    }
  </script>
</PageLayout>
