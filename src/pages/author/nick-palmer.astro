---
import PageLayout from '~/layouts/PageLayout.astro';
import PageHero from '~/components/directory/PageHero.astro';
import config from '~/config';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => (b.data.pubDate?.getTime() || 0) - (a.data.pubDate?.getTime() || 0));

const author = config.editorialAuthor;
const totalPosts = allPosts.length;

const title = `${author.name} — ${author.title}`;
const description = `${author.name} is the ${author.title.toLowerCase()} at ${config.brandName}. ${totalPosts} published articles on ${config.servicePhrase}, costs, certifications, and hiring.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: author.name,
    jobTitle: author.title,
    description: author.bio,
    url: `${config.siteUrl}/author/nick-palmer/`,
    worksFor: {
      '@type': 'Organization',
      name: config.brandName,
      url: config.siteUrl,
    },
    knowsAbout: [
      config.primaryKeyword,
      config.industry,
      config.servicePhrase,
      config.primaryCredential,
      ...config.secondaryKeywords,
    ],
    ...(author.linkedin ? { sameAs: [author.linkedin] } : {}),
  },
};

const metadata = { title, description };

// Group posts by category
const categories = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  const tags = post.data.tags || [];
  let cat = 'General';
  if (tags.includes('pillar') || tags.includes('guide')) cat = 'Guides';
  else if (tags.some(t => t.includes('cost') || t.includes('salary') || t.includes('cheap'))) cat = 'Cost & Pricing';
  else if (tags.some(t => t.includes('cert') || t.includes('CLVS') || t.includes('legal'))) cat = 'Certifications & Legal';
  else if (tags.some(t => t.includes('hiring') || t.includes('choose') || t.includes('red flag'))) cat = 'Hiring';
  else if (tags.some(t => t.includes('city') || t.includes('best'))) cat = 'City Guides';
  else if (tags.some(t => t.includes('industry') || t.includes('trend') || t.includes('AI'))) cat = 'Industry';

  if (!categories.has(cat)) categories.set(cat, []);
  categories.get(cat)!.push(post);
}
---
<PageLayout metadata={metadata} hero="dark">
  <Fragment slot="announcement"><span></span></Fragment>

  <PageHero
    title={author.name}
    breadcrumbs={[{ label: 'Blog', href: '/blog/' }, { label: author.name }]}
  >
    <div class="flex items-start gap-6 mt-2">
      <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary-400 to-primary-700 flex items-center justify-center text-3xl font-bold text-white flex-shrink-0 shadow-lg">
        {author.name.charAt(0)}
      </div>
      <div>
        <p class="text-primary-200 text-lg">{author.title} at {config.brandName}</p>
        <p class="text-white/70 mt-3 max-w-2xl leading-relaxed">{author.bio}</p>
        <div class="flex items-center gap-4 mt-4">
          {author.linkedin && (
            <a href={author.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-primary-200 hover:text-white transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          )}
          <span class="text-sm text-primary-300/60">{totalPosts} published articles</span>
        </div>
      </div>
    </div>
  </PageHero>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-2">Expertise</h2>
    <div class="flex flex-wrap gap-2 mb-10">
      {[config.servicePhrase, config.primaryCredential, `${config.primaryKeyword || config.name} Costs`, 'Industry Trends', 'Hiring Best Practices', ...config.secondaryKeywords.slice(0, 2)].map(topic => (
        <span class="px-3 py-1 bg-primary-50 text-primary-700 text-sm font-medium rounded-full border border-primary-100">{topic}</span>
      ))}
    </div>

    <h2 class="text-2xl font-bold text-gray-900 mb-6">Published Articles</h2>

    {Array.from(categories.entries()).map(([category, posts]) => (
      <div class="mb-10">
        <h3 class="text-lg font-semibold text-gray-700 mb-4 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-500"></span>
          {category}
          <span class="text-sm font-normal text-gray-400">({posts.length})</span>
        </h3>
        <div class="space-y-3">
          {posts.map(post => (
            <a href={`/blog/${post.id}/`} class="block group p-4 rounded-lg border border-gray-100 hover:border-primary-200 hover:bg-primary-50/50 transition-all no-underline">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h4 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">{post.data.title}</h4>
                  {post.data.description && (
                    <p class="text-sm text-gray-500 mt-1 line-clamp-1">{post.data.description}</p>
                  )}
                </div>
                <time class="text-xs text-gray-400 whitespace-nowrap flex-shrink-0 mt-1" datetime={post.data.pubDate?.toISOString()}>
                  {post.data.pubDate?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
