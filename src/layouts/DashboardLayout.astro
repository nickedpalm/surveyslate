---
import '~/assets/styles/tailwind.css';
import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';

export interface Props {
  title: string;
  activePage: string;
}

const { title, activePage } = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <CommonMeta />
    <Favicons />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="preload" href="/_astro/inter-latin-wght-normal.BgVq2Tq4.woff2" as="font" type="font/woff2" crossorigin />
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Inter', -apple-system, sans-serif; background: #f5f6f8; color: #1a1a2e; }

      /* Sidebar */
      .dash-layout { display: flex; min-height: 100vh; }
      .dash-sidebar {
        width: 240px; background: #1a1a2e; color: #fff; padding: 24px 0;
        display: flex; flex-direction: column; position: fixed; top: 0; bottom: 0; z-index: 50;
      }
      .dash-logo { font-size: 20px; font-weight: 800; color: #fff; padding: 0 24px 28px; text-decoration: none; display: block; }
      .dash-logo span { color: #60a5fa; }
      .dash-section { font-size: 10px; font-weight: 700; color: #4b5563; text-transform: uppercase; letter-spacing: 1.5px; padding: 16px 24px 8px; }
      .dash-nav-item {
        display: flex; align-items: center; gap: 12px; padding: 10px 24px;
        font-size: 14px; font-weight: 500; color: #94a3b8; cursor: pointer;
        transition: all 0.15s; text-decoration: none; border-left: 3px solid transparent;
      }
      .dash-nav-item:hover { color: #fff; background: rgba(255,255,255,0.05); }
      .dash-nav-item.active { color: #fff; background: rgba(59,130,246,0.15); border-left-color: #3b82f6; }
      .dash-nav-item .icon { width: 20px; text-align: center; font-size: 16px; }
      .dash-nav-item .badge {
        margin-left: auto; background: #ef4444; color: #fff; font-size: 11px;
        font-weight: 700; padding: 1px 7px; border-radius: 10px; min-width: 20px; text-align: center;
      }
      .dash-nav-item .badge.blue { background: #3b82f6; }
      .dash-sidebar-bottom { margin-top: auto; padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.08); }
      .dash-user { display: flex; align-items: center; gap: 10px; }
      .dash-avatar {
        width: 34px; height: 34px; background: #2563eb; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 700; color: #fff;
      }
      .dash-user-name { font-size: 13px; font-weight: 600; }
      .dash-user-plan { font-size: 11px; color: #6b7280; }

      /* Main */
      .dash-main { margin-left: 240px; flex: 1; padding: 32px 40px; min-height: 100vh; }

      /* Topbar */
      .dash-topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
      .dash-topbar h1 { font-size: 24px; font-weight: 800; }
      .dash-topbar-sub { font-size: 14px; color: #6b7280; margin-top: 2px; }

      /* Buttons */
      .dash-btn {
        padding: 10px 18px; border-radius: 10px; font-size: 13px; font-weight: 600;
        cursor: pointer; border: none; transition: all 0.15s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
      }
      .dash-btn-primary { background: #2563eb; color: #fff; }
      .dash-btn-primary:hover { background: #1d4ed8; }
      .dash-btn-outline { background: #fff; color: #374151; border: 1.5px solid #d1d5db; }
      .dash-btn-outline:hover { border-color: #9ca3af; }
      .dash-btn-upgrade { background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; }
      .dash-btn-upgrade:hover { transform: scale(1.02); }

      /* Cards */
      .dash-card { background: #fff; border-radius: 14px; border: 1px solid #e5e7eb; overflow: hidden; }
      .dash-card-header {
        padding: 18px 22px; border-bottom: 1px solid #f3f4f6;
        display: flex; align-items: center; justify-content: space-between;
      }
      .dash-card-header h2 { font-size: 15px; font-weight: 700; }
      .dash-card-body { padding: 22px; }

      /* Stats */
      .dash-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
      .dash-stat {
        background: #fff; border-radius: 14px; padding: 20px; border: 1px solid #e5e7eb;
      }
      .dash-stat-label { font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
      .dash-stat-value { font-size: 32px; font-weight: 800; color: #1a1a2e; }
      .dash-stat-change { font-size: 12px; font-weight: 600; margin-top: 4px; }
      .dash-stat-change.up { color: #059669; }
      .dash-stat-change.neutral { color: #6b7280; }
      .dash-stat-spark { display: flex; align-items: flex-end; gap: 3px; margin-top: 12px; height: 32px; }
      .spark-bar { flex: 1; background: #e0e7ff; border-radius: 2px; min-width: 4px; }
      .spark-bar.current { background: #2563eb; }

      /* Two column */
      .dash-two-col { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; margin-bottom: 28px; }

      /* Upgrade banner */
      .dash-upgrade-banner {
        background: linear-gradient(135deg, #1e293b 0%, #1e3a5f 50%, #1e40af 100%);
        border-radius: 16px; padding: 24px 28px; margin-bottom: 28px;
        display: flex; align-items: center; justify-content: space-between;
        color: #fff; position: relative; overflow: hidden;
      }
      .dash-upgrade-banner::before {
        content: ''; position: absolute; top: -50%; right: -10%;
        width: 300px; height: 300px; background: rgba(59,130,246,0.15);
        border-radius: 50%; pointer-events: none;
      }
      .dash-upgrade-banner h3 { font-size: 17px; font-weight: 700; margin-bottom: 4px; position: relative; z-index: 1; }
      .dash-upgrade-banner p { font-size: 13px; color: #93c5fd; line-height: 1.4; position: relative; z-index: 1; }
      .dash-upgrade-banner .highlight { color: #fbbf24; font-weight: 700; }

      /* Form inputs */
      .dash-input {
        width: 100%; padding: 10px 14px; border-radius: 10px; border: 1.5px solid #d1d5db;
        font-size: 14px; font-family: inherit; transition: border-color 0.15s, box-shadow 0.15s;
        background: #fff; color: #1a1a2e;
      }
      .dash-input:focus { outline: none; border-color: #93c5fd; box-shadow: 0 0 0 3px rgba(147,197,253,0.3); }
      textarea.dash-input { resize: vertical; }

      /* Toggle switch */
      .dash-toggle { position: relative; width: 44px; height: 24px; cursor: pointer; }
      .dash-toggle input { opacity: 0; width: 0; height: 0; }
      .dash-toggle-slider {
        position: absolute; inset: 0; background: #d1d5db; border-radius: 12px; transition: 0.2s;
      }
      .dash-toggle-slider::before {
        content: ''; position: absolute; height: 18px; width: 18px; left: 3px; bottom: 3px;
        background: #fff; border-radius: 50%; transition: 0.2s;
      }
      .dash-toggle input:checked + .dash-toggle-slider { background: #2563eb; }
      .dash-toggle input:checked + .dash-toggle-slider::before { transform: translateX(20px); }

      /* Quote items */
      .dash-quote {
        padding: 16px 22px; border-bottom: 1px solid #f3f4f6;
        display: flex; align-items: flex-start; gap: 14px;
        transition: background 0.1s; cursor: pointer;
      }
      .dash-quote:last-child { border-bottom: none; }
      .dash-quote:hover { background: #f8fafc; }
      .dash-quote.unread { background: #fefce8; }
      .dash-quote.unread:hover { background: #fef9c3; }
      .dash-quote-avatar {
        width: 38px; height: 38px; border-radius: 50%; background: #e0e7ff;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 600; color: #4338ca; flex-shrink: 0;
      }

      /* Completeness ring */
      .dash-ring { width: 100px; height: 100px; margin: 0 auto 16px; position: relative; }
      .dash-ring svg { transform: rotate(-90deg); }
      .dash-ring .pct {
        position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
        font-size: 24px; font-weight: 800; color: #1a1a2e;
      }

      /* Status badges */
      .status-new { background: #fef3c7; color: #92400e; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 4px; }
      .status-replied { background: #ecfdf5; color: #059669; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 4px; }

      /* Loading */
      .dash-loading {
        min-height: 100vh; display: flex; align-items: center; justify-content: center;
      }
      .dash-spinner {
        width: 32px; height: 32px; border: 3px solid #e5e7eb; border-top-color: #2563eb;
        border-radius: 50%; animation: spin 0.6s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* Mobile top bar */
      .dash-mobile-bar {
        display: none; position: fixed; top: 0; left: 0; right: 0; z-index: 60;
        height: 56px; background: #1a1a2e; padding: 0 16px;
        align-items: center; justify-content: space-between;
      }
      .dash-mobile-bar .dash-logo { padding: 0; font-size: 18px; }
      .dash-hamburger {
        background: none; border: none; cursor: pointer; padding: 8px;
        display: flex; flex-direction: column; gap: 5px;
      }
      .dash-hamburger span {
        display: block; width: 22px; height: 2px; background: #fff; border-radius: 1px;
      }

      /* Sidebar close button */
      .dash-sidebar-close {
        display: none; position: absolute; top: 16px; right: 16px;
        background: none; border: none; cursor: pointer; color: #94a3b8;
        font-size: 24px; line-height: 1; padding: 4px;
      }
      .dash-sidebar-close:hover { color: #fff; }

      /* Mobile overlay backdrop */
      .dash-overlay {
        display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5);
        z-index: 45;
      }

      /* Mobile */
      @media (max-width: 768px) {
        .dash-mobile-bar { display: flex; }
        .dash-sidebar {
          display: flex; transform: translateX(-100%); transition: transform 0.25s ease;
        }
        .dash-sidebar.open { transform: translateX(0); }
        .dash-sidebar-close { display: block; }
        .dash-overlay.open { display: block; }
        .dash-main { margin-left: 0; padding: 72px 16px 16px; }
        .dash-stats { grid-template-columns: repeat(2, 1fr); }
        .dash-two-col { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <!-- Loading overlay -->
    <div id="dash-loading" class="dash-loading">
      <div style="text-align:center">
        <div class="dash-spinner" style="margin:0 auto 12px"></div>
        <p style="font-size:14px;color:#6b7280">Loading dashboard...</p>
      </div>
    </div>

    <!-- Dashboard layout (hidden until auth verified) -->
    <div id="dash-app" class="dash-layout" style="display:none">
      <!-- Mobile top bar -->
      <div class="dash-mobile-bar">
        <a href="/" class="dash-logo"><img src="/logo-dark.png" alt="Dashboard" style="height:28px;width:auto;" /></a>
        <button class="dash-hamburger" id="dash-menu-toggle" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </div>
      <!-- Mobile overlay -->
      <div class="dash-overlay" id="dash-overlay"></div>

      <aside class="dash-sidebar" id="dash-sidebar">
        <button class="dash-sidebar-close" id="dash-sidebar-close" aria-label="Close menu">&times;</button>
        <a href="/" class="dash-logo"><img src="/logo-dark.png" alt="Dashboard" style="height:28px;width:auto;" /></a>

        <div class="dash-section">Dashboard</div>
        <a class={`dash-nav-item ${activePage === 'overview' ? 'active' : ''}`} href="/provider/dashboard/">
          <span class="icon">&#x1f4ca;</span> Overview
        </a>
        <a class={`dash-nav-item ${activePage === 'quotes' ? 'active' : ''}`} href="/provider/dashboard/quotes/">
          <span class="icon">&#x1f4e9;</span> Quote Requests
          <span id="nav-quotes-badge" class="badge" style="display:none"></span>
        </a>
        <a class={`dash-nav-item ${activePage === 'reviews' ? 'active' : ''}`} href="/provider/dashboard/reviews/">
          <span class="icon">&#x2b50;</span> Reviews
        </a>

        <div class="dash-section">Your Listing</div>
        <a class={`dash-nav-item ${activePage === 'profile' ? 'active' : ''}`} href="/provider/dashboard/profile/">
          <span class="icon">&#x1f3e2;</span> Edit Profile
        </a>
        <a class={`dash-nav-item ${activePage === 'photos' ? 'active' : ''}`} href="/provider/dashboard/photos/">
          <span class="icon">&#x1f4f7;</span> Photos
        </a>
        <a class={`dash-nav-item ${activePage === 'service-area' ? 'active' : ''}`} href="/provider/dashboard/service-area/">
          <span class="icon">&#x1f5fa;&#xfe0f;</span> Service Area
        </a>
        <a id="nav-view-listing" class="dash-nav-item" href="#" target="_blank">
          <span class="icon">&#x1f441;&#xfe0f;</span> View Live Listing
        </a>

        <div class="dash-section">Account</div>
        <a class={`dash-nav-item ${activePage === 'billing' ? 'active' : ''}`} href="/provider/dashboard/billing/">
          <span class="icon">&#x1f4b3;</span> Billing
        </a>
        <a class={`dash-nav-item ${activePage === 'settings' ? 'active' : ''}`} href="/provider/dashboard/settings/">
          <span class="icon">&#x2699;&#xfe0f;</span> Settings
        </a>

        <div class="dash-sidebar-bottom">
          <div class="dash-user">
            <div class="dash-avatar" id="nav-avatar">?</div>
            <div>
              <div class="dash-user-name" id="nav-user-name">Loading...</div>
              <div class="dash-user-plan" id="nav-user-plan">Free Plan</div>
            </div>
          </div>
        </div>
      </aside>

      <main class="dash-main">
        <slot />
      </main>
    </div>

    <script is:inline>
      // Global dashboard auth + state
      window.dashState = {
        provider: null,
        listings: [],
        currentSlug: null,
        listingData: {},
      };

      (async function initDashAuth() {
        try {
          var resp = await fetch('/api/auth/session', { credentials: 'include' });
          var data = await resp.json();
          if (!data.authenticated) {
            var params = new URLSearchParams(window.location.search);
            var listing = params.get('listing');
            window.location.href = listing
              ? '/provider/login?listing=' + encodeURIComponent(listing)
              : '/provider/login';
            return;
          }
          window.dashState.provider = data.provider;
          window.dashState.listings = data.listings || [];

          var params = new URLSearchParams(window.location.search);
          window.dashState.currentSlug = params.get('listing') || window.dashState.listings[0] || null;

          // Update sidebar
          var p = data.provider;
          var initials = (p.name || p.email || '??').substring(0, 2).toUpperCase();
          document.getElementById('nav-avatar').textContent = initials;
          document.getElementById('nav-user-name').textContent = p.name || p.email.split('@')[0];

          if (window.dashState.currentSlug) {
            document.getElementById('nav-view-listing').href = '/listing/' + window.dashState.currentSlug + '/';
          }

          // Show app
          document.getElementById('dash-loading').style.display = 'none';
          document.getElementById('dash-app').style.display = 'flex';

          // Fire ready event for page-specific scripts
          window.dispatchEvent(new CustomEvent('dash-ready'));
        } catch (err) {
          window.location.href = '/provider/login';
        }
      })();
    </script>

    <script is:inline>
      // Mobile sidebar toggle
      (function() {
        var toggle = document.getElementById('dash-menu-toggle');
        var sidebar = document.getElementById('dash-sidebar');
        var overlay = document.getElementById('dash-overlay');
        var close = document.getElementById('dash-sidebar-close');

        function openMenu() {
          sidebar.classList.add('open');
          overlay.classList.add('open');
        }
        function closeMenu() {
          sidebar.classList.remove('open');
          overlay.classList.remove('open');
        }

        toggle.addEventListener('click', openMenu);
        close.addEventListener('click', closeMenu);
        overlay.addEventListener('click', closeMenu);
      })();
    </script>
  </body>
</html>
